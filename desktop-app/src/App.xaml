<Application x:Class="QuantumTrader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             DispatcherUnhandledException="Application_DispatcherUnhandledException">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Load simple styles first as fallback -->
                <ResourceDictionary Source="Themes/SimpleStyles.xaml"/>
                <!-- Load base colors and themes -->
                <ResourceDictionary Source="Themes/NexusTheme.xaml"/>
                <ResourceDictionary Source="Themes/NexusAITheme.xaml"/>
                <!-- Load styles that depend on colors -->
                <ResourceDictionary Source="Themes/NexusWindowStyles.xaml"/>
                <!-- Load compatibility layer last -->
                <ResourceDictionary Source="Themes/Compat.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
