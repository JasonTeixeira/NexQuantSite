<Window x:Class="QuantumTrader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:QuantumTrader.Views"
        xmlns:res="clr-namespace:QuantumTrader.Resources"
        Title="NEXUS AI TRADING"
        Height="900" Width="1600"
        Style="{DynamicResource NexusWindow}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/App.ico"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid Background="{StaticResource NexusAIBackgroundPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource NexusAIBackgroundSecondary}"
                BorderBrush="{StaticResource NexusAIBorderPrimary}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                    <Viewbox Height="32" Width="32" Margin="0,0,12,0">
                        <res:LogoControl />
                    </Viewbox>
                    <TextBlock Text="NEXUS AI"
                               VerticalAlignment="Center"
                               FontSize="18"
                       FontWeight="Bold"
                               Foreground="{StaticResource NexusTextPrimary}"/>
                                         <TextBlock Text="TRADING"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="8,0,0,0"
                               Foreground="{StaticResource NexusAccentPrimary}"/>
                </StackPanel>

                <!-- Center ticker -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🟢 Live • Market Open"
                             Foreground="{StaticResource NexusTextSecondary}"
                             FontSize="14"
                             VerticalAlignment="Center"/>
                    <ItemsControl x:Name="Watchlist" Margin="16,0,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource NexusAIBackgroundTertiary}" CornerRadius="6" Margin="4" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Price, StringFormat=C}" Foreground="{StaticResource NexusAITextPrimary}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0">
                    <!-- Broker Selection -->
                    <Border Style="{StaticResource NexusCard}" Padding="8,4" Margin="0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏦"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     Margin="0,0,4,0"/>
                            <ComboBox x:Name="BrokerSelectionComboBox"
                                      Width="120"
                                      Height="26"
                                      Background="#1E2230"
                                      Foreground="#FFFFFF"
                                      BorderBrush="#00D4FF"
                                      BorderThickness="1"
                                      FontSize="11"
                                      VerticalAlignment="Center"
                                      SelectionChanged="BrokerSelectionComboBox_SelectionChanged">
                                <ComboBoxItem Content="NinjaTrader" IsSelected="True"/>
                                <ComboBoxItem Content="Alpaca"/>
                                <ComboBoxItem Content="InteractiveBrokers"/>
                                <ComboBoxItem Content="Tradovate"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NexusCard}" Padding="12,4" Margin="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Portfolio"
                                     Foreground="{StaticResource NexusTextTertiary}"
                                     FontSize="12"
                                     Margin="0,0,8,0"/>
                            <TextBlock x:Name="HeaderBalanceValue"
                                       Text="$287,450"
                                     Foreground="{StaticResource NexusTextPrimary}"
                                     FontWeight="Bold"
                                     Style="{StaticResource NexusTextMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NexusCard}" Padding="12,4" Margin="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Credits"
                                     Foreground="{StaticResource NexusTextTertiary}"
                                     FontSize="12"
                                     Margin="0,0,8,0"/>
                            <TextBlock x:Name="CreditsText"
                                       Text="2,847"
                                     Foreground="{StaticResource NexusAccentPrimary}"
                                     FontWeight="Bold"
                                     Style="{StaticResource NexusTextMono}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content - 5 TAB STRUCTURE -->
        <TabControl Grid.Row="1" Style="{StaticResource NexusTabControl}" Margin="0">

            <!-- TAB 1: LIVE TRADING DASHBOARD -->
            <TabItem Header="🎯 Live Trading" Style="{StaticResource NexusTabItem}">
                <views:LiveTradingView x:Name="LiveTradingView" />
            </TabItem>


            <!-- TAB 2: DASHBOARD -->
            <TabItem Header="📊 Dashboard" Style="{StaticResource NexusTabItem}">
                <views:DashboardView x:Name="DashboardView" />
            </TabItem>

            <!-- TAB 3: STRATEGY HUB -->
            <TabItem Header="🤖 Strategy Hub" Style="{StaticResource NexusTabItem}">
                <views:StrategyHubView x:Name="StrategyHubView" />
            </TabItem>

            <!-- TAB 4: STRATEGY STORE -->
            <TabItem Header="🛒 Strategy Store" Style="{StaticResource NexusTabItem}">
                <views:StrategyStoreView x:Name="StrategyStoreView" />
            </TabItem>

            <!-- TAB 5: ANALYTICS -->
            <TabItem Header="📈 Analytics" Style="{StaticResource NexusTabItem}">
                <views:AnalyticsView x:Name="AnalyticsView" />
            </TabItem>

                    </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource NexusBackgroundSecondary}"
                BorderBrush="{StaticResource NexusBorderPrimary}"
                BorderThickness="0,1,0,0"
                Padding="16,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="StatusModeText"
                           Text="MODE: DEMO (Stub)"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="🔗"
                             VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <TextBlock x:Name="MlHealthText"
                               Text="ML Service: Connected"
                             VerticalAlignment="Center"
                               FontSize="12"/>
                </StackPanel>
            </Grid>
            </Border>
    </Grid>
</Window>
