            <!-- TAB 5: Strategy Lab (Modern) -->
            <TabItem Header="🧪 Strategy Lab (Modern)">
                <TabItem.Resources>
                    <Style x:Key="ModernPrimaryButton" TargetType="Button">
                        <Setter Property="Background" Value="#00D4FF"/>
                        <Setter Property="Foreground" Value="#0F1419"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#00D4FF"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#19E1FF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#12BFE0"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernPrimaryButton}">
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="BorderBrush" Value="#404040"/>
                    </Style>

                    <Style x:Key="ModernTextBox" TargetType="TextBox">
                        <Setter Property="Background" Value="#1E2936"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderBrush" Value="#2F3E4E"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CaretBrush" Value="#00D4FF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="CardStyle" TargetType="Border">
                        <Setter Property="Background" Value="#121A23"/>
                        <Setter Property="CornerRadius" Value="10"/>
                        <Setter Property="Padding" Value="18"/>
                        <Setter Property="Margin" Value="0,0,0,16"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="10" ShadowDepth="0"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabItem.Resources>

                <ScrollViewer>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Controls -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Strategy Lab" FontSize="22" FontWeight="Bold" Foreground="#00D4FF"/>
                            <TextBlock Text="Design, test, and optimize strategies with AI" Foreground="#8B949E" Margin="0,4,0,16"/>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Credits" FontSize="14" FontWeight="Bold" Foreground="#00FF88"/>
                                    <TextBlock x:Name="ModernAvailableCredits" Text="" FontSize="22" FontWeight="Bold" Foreground="#00FF88" Margin="0,6,0,10"/>
                                    <Button Content="Add Credits" Style="{StaticResource ModernPrimaryButton}" Click="AddCredits_Click"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Strategy Name" Foreground="#8B949E"/>
                                    <TextBox x:Name="ModernStrategyName" Style="{StaticResource ModernTextBox}" Text="My AI Strategy" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Vertical">
                                <Button Content="Generate with AI" Style="{StaticResource ModernPrimaryButton}" Click="GenerateStrategyWithAI_Click" Margin="0,0,0,10"/>
                                <Button Content="Quick Backtest" Style="{StaticResource ModernSecondaryButton}" Click="BacktestStrategy_Click" Margin="0,0,0,10"/>
                                <Button Content="Optimize" Style="{StaticResource ModernSecondaryButton}" Click="OptimizeStrategy_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Center: Code Editor -->
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="AI Code Editor" FontSize="14" FontWeight="Bold" Foreground="#00D4FF"/>
