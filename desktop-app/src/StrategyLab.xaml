                                <ComboBoxItem Content="🤖 Claude 3.5 Sonnet (Quantitative Analysis)"/>
                                <ComboBoxItem Content="⚡ Claude 3.5 Haiku (Fast Execution)"/>
                                <ComboBoxItem Content="🎯 Custom Fine-tuned Model"/>
                                <ComboBoxItem Content="🔬 Ensemble (Multi-Model)"/>
                                <ComboBoxItem Content="🧠 LLaMA 3 (Open Source)"/>
                                <ComboBoxItem Content="🎲 Custom Neural Network"/>
