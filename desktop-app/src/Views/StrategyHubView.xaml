<UserControl x:Class="QuantumTrader.Views.StrategyHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Professional Toolbar -->
        <Border Grid.Row="0"
                Background="#1A1A25"
                BorderBrush="#2A2A3E"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📋 Templates"
                            Command="{Binding ShowTemplatesCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>

                    <Button Content="🎨 Builder"
                            Command="{Binding ShowBuilderCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>

                    <Button Content="💻 Code"
                            Command="{Binding ShowCodeEditorCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>

                    <Button Content="📊 Backtest"
                            Command="{Binding ShowBacktestCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>

                    <Button Content="🚀 Deploy"
                            Command="{Binding ShowDeployCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>
                </StackPanel>

                <!-- Active Strategy Info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🎯" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ActiveWorkspace.Name, FallbackValue='No Strategy Selected'}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                    <TextBlock Text="●"
                               Foreground="Orange"
                               Margin="8,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="💾 Save"
                            Command="{Binding SaveStrategyCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>

                    <Button Content="🔨 Compile"
                            Command="{Binding CompileStrategyCommand}"
                            Style="{StaticResource NexusButton}"
                            Margin="0,0,8,0"/>

                    <Button Content="▶️ Backtest"
                            Command="{Binding RunBacktestCommand}"
                            Style="{StaticResource NexusButton}"
                            Background="#228B22"
                            Margin="0,0,8,0"/>

                    <ProgressBar Width="100"
                                 Height="20"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsBacktesting, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Foreground="#00BBFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">

            <!-- TEMPLATES VIEW -->
            <ScrollViewer Visibility="Visible">
                <StackPanel Margin="20">

                    <!-- Search and Filter -->
                    <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource NexusTextBox}"
                                     FontSize="14"
                                     Margin="0,0,16,0">
                                <TextBox.Resources>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource NexusTextBox}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Opacity="0.3" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Search strategies..."
                                                                          Foreground="#888"
                                                                          FontStyle="Italic"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding FilterCategories}"
                                      SelectedItem="{Binding CategoryFilter}"
                                      Style="{StaticResource NexusComboBox}"
                                      Margin="0,0,16,0"/>

                            <Button Grid.Column="2"
                                    Content="➕ New Strategy"
                                    Command="{Binding CreateNewStrategyCommand}"
                                    Style="{StaticResource NexusButton}"
                                    Background="#228B22"/>
                        </Grid>
                    </Border>

                    <!-- Strategy Templates Grid -->
                    <TextBlock Text="🏛️ PROFESSIONAL STRATEGY TEMPLATES"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding StrategyTemplates}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="320"
                                        Height="240"
                                        Background="#1A1A25"
                                        CornerRadius="12"
                                        BorderBrush="#2A2A3E"
                                        BorderThickness="1"
                                        Margin="0,0,16,16"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.CreateNewStrategyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <Grid Margin="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="16"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="💎"
                                                           Visibility="{Binding IsPremium, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Price, StringFormat='${0:F0}'}"
                                                           Foreground="#FFD700"
                                                           FontWeight="Bold"
                                                           Visibility="{Binding IsPremium, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Description -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Description}"
                                                   Foreground="#B0B0C8"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,12"/>

                                        <!-- Metrics -->
                                        <Grid Grid.Row="2" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="RETURN" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding BacktestReturn, StringFormat='{}{0:F1}%'}"
                                                           Foreground="Green"
                                                           FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="SHARPE" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding SharpeRatio, StringFormat='{}{0:F2}'}"
                                                           Foreground="#00BBFF"
                                                           FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="WIN RATE" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding WinRate, StringFormat='{}{0:F1}%'}"
                                                           Foreground="Orange"
                                                           FontWeight="Bold"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Footer -->
                                        <Grid Grid.Row="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="⭐" FontSize="12"/>
                                                <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}"
                                                           Foreground="White"
                                                           FontSize="12"
                                                           Margin="4,0,8,0"/>
                                                <TextBlock Text="{Binding Downloads, StringFormat='({0:N0} downloads)'}"
                                                           Foreground="#888"
                                                           FontSize="10"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Background="Orange"
                                                    CornerRadius="10"
                                                    Padding="8,2">
                                                <TextBlock Text="{Binding Complexity}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- VISUAL BUILDER VIEW -->
            <Grid Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Component Library -->
                <Border Grid.Column="0"
                        Background="#15151F"
                        BorderBrush="#2A2A3E"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer>
                        <StackPanel Margin="16">
                            <TextBlock Text="🧰 COMPONENT LIBRARY"
                                       Style="{StaticResource NexusHeaderSmall}"
                                       Margin="0,0,0,16"/>

                            <!-- Indicators -->
                            <Expander Header="📈 Indicators" IsExpanded="True">
                                <ItemsControl ItemsSource="{Binding ComponentLibrary}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A1A25"
                                                    CornerRadius="6"
                                                    Margin="0,2"
                                                    Padding="8"
                                                    Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.AddComponentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#888"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Visual Canvas -->
                <Border Grid.Column="1" Background="#0F0F1A">
                    <Grid>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas Width="2000" Height="2000">
                                <!-- Grid lines -->
                                <Canvas.Background>
                                    <DrawingBrush Viewport="0,0,50,50" ViewportUnits="Absolute" TileMode="Tile">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing Brush="Transparent">
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="0,0,50,50"/>
                                                </GeometryDrawing.Geometry>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="#1A1A25" Thickness="1"/>
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Canvas.Background>

                                <!-- Strategy Components -->
                                <ItemsControl ItemsSource="{Binding ActiveWorkspace.Components}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="120"
                                                    Height="80"
                                                    Background="#2A2A3E"
                                                    CornerRadius="8"
                                                    BorderBrush="#00BBFF"
                                                    BorderThickness="2"
                                                    Cursor="Hand">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}" FontSize="18" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                        </ScrollViewer>

                        <!-- Canvas Instructions -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="🎨" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="VISUAL STRATEGY BUILDER"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Opacity="0.6"/>
                            <TextBlock Text="Drag components from the library to build your strategy"
                                       Foreground="#888"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Properties Panel -->
                <Border Grid.Column="2"
                        Background="#15151F"
                        BorderBrush="#2A2A3E"
                        BorderThickness="1,0,0,0">
                    <ScrollViewer>
                        <StackPanel Margin="16">
                            <TextBlock Text="⚙️ PROPERTIES"
                                       Style="{StaticResource NexusHeaderSmall}"
                                       Margin="0,0,0,16"/>

                            <!-- Component properties will be shown here -->
                            <TextBlock Text="Select a component to edit properties"
                                       Foreground="#888"
                                       FontStyle="Italic"
                                       Visibility="Visible"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- CODE EDITOR VIEW -->
            <Grid Visibility="Collapsed">
                <Border Style="{StaticResource NexusCard}" Margin="20">
                    <StackPanel>
                        <TextBlock Text="💻 ADVANCED CODE EDITOR"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <ScrollViewer Height="600" VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding ActiveWorkspace.SourceCode, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Background="#0F0F1A"
                                     Foreground="White"
                                     BorderThickness="0"
                                     TextWrapping="NoWrap"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- BACKTEST RESULTS VIEW -->
            <ScrollViewer Visibility="Collapsed">
                <StackPanel Margin="20">

                    <!-- Backtest Parameters -->
                    <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="📊 BACKTEST PARAMETERS"
                                       Style="{StaticResource NexusHeaderMedium}"
                                       Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Start Date" Style="{StaticResource NexusTextCaption}"/>
                                    <DatePicker SelectedDate="{Binding BacktestStartDate}"
                                               Style="{StaticResource NexusDatePicker}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                    <TextBlock Text="End Date" Style="{StaticResource NexusTextCaption}"/>
                                    <DatePicker SelectedDate="{Binding BacktestEndDate}"
                                               Style="{StaticResource NexusDatePicker}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                    <TextBlock Text="Initial Capital" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBox Text="{Binding BacktestCapital, StringFormat='N0'}"
                                            Style="{StaticResource NexusTextBox}"/>
                                </StackPanel>

                                <Button Grid.Column="3"
                                        Content="▶️ Run Backtest"
                                        Command="{Binding RunBacktestCommand}"
                                        Style="{StaticResource NexusButton}"
                                        Background="#228B22"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Backtest Results -->
                    <Border Style="{StaticResource NexusCard}"
                            Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="📈 BACKTEST RESULTS"
                                       Style="{StaticResource NexusHeaderMedium}"
                                       Margin="0,0,0,16"/>

                            <!-- Key Metrics -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TOTAL RETURN" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.TotalReturnPercent, StringFormat='{}{0:F2}%'}"
                                               Foreground="Green"
                                               FontSize="24"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="SHARPE RATIO" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.SharpeRatio, StringFormat='{}{0:F2}'}"
                                               Foreground="#00BBFF"
                                               FontSize="24"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="MAX DRAWDOWN" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.MaxDrawdownPercent, StringFormat='{}{0:F2}%'}"
                                               Foreground="Orange"
                                               FontSize="24"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="WIN RATE" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.WinRate, StringFormat='{}{0:F1}%'}"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <!-- Additional Metrics -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                    <TextBlock Text="Total Trades" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.TotalTrades}"
                                               Foreground="White"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                    <TextBlock Text="Profit Factor" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.ProfitFactor, StringFormat='{}{0:F2}'}"
                                               Foreground="White"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                                    <TextBlock Text="Average Win" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.AverageWin, StringFormat='${0:F2}'}"
                                               Foreground="Green"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,12">
                                    <TextBlock Text="Average Loss" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.AverageLoss, StringFormat='${0:F2}'}"
                                               Foreground="Red"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Execution Time" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.ExecutionTime, StringFormat='{}{0:F1}s'}"
                                               Foreground="#888"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Sortino Ratio" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.SortinoRatio, StringFormat='{}{0:F2}'}"
                                               Foreground="White"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock Text="Volatility" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.Volatility, StringFormat='{}{0:P1}'}"
                                               Foreground="White"
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="3">
                                    <TextBlock Text="Final Capital" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="{Binding LastBacktestResult.FinalCapital, StringFormat='${0:N0}'}"
                                               Foreground="White"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- DEPLOY VIEW -->
            <StackPanel Visibility="Collapsed"
                        Margin="20">
                <Border Style="{StaticResource NexusCard}">
                    <StackPanel>
                        <TextBlock Text="🚀 DEPLOY STRATEGY TO LIVE TRADING"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Strategy deployment functionality will be implemented here."
                                   Foreground="#888"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
