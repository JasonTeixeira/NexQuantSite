                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,10,0,0">
                                    <TextBlock Text="Top P" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                    <Slider x:Name="TopPSlider" Minimum="0.1" Maximum="1" Value="0.9"
                                            Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                    <TextBlock x:Name="TopPValue" Text="0.9" FontSize="10"
                                               Foreground="{StaticResource AccentBlue}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Strategy Type -->
                        <TextBlock Text="📈 STRATEGY TYPE" FontSize="16" FontWeight="Bold"
