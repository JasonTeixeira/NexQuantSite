<svg width="128" height="128" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="iconGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#06b6d4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:1" />
    </linearGradient>
    <filter id="iconGlow">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge> 
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background circle -->
  <circle cx="64" cy="64" r="60" fill="url(#iconGrad)" filter="url(#iconGlow)"/>
  
  <!-- Neural network pattern -->
  <g stroke="#ffffff" stroke-width="2" fill="none" opacity="0.9">
    <!-- Nodes -->
    <circle cx="40" cy="35" r="4" fill="#ffffff"/>
    <circle cx="64" cy="25" r="4" fill="#ffffff"/>
    <circle cx="88" cy="35" r="4" fill="#ffffff"/>
    
    <circle cx="30" cy="64" r="4" fill="#ffffff"/>
    <circle cx="64" cy="64" r="6" fill="#ffffff"/> <!-- Central node larger -->
    <circle cx="98" cy="64" r="4" fill="#ffffff"/>
    
    <circle cx="40" cy="93" r="4" fill="#ffffff"/>
    <circle cx="64" cy="103" r="4" fill="#ffffff"/>
    <circle cx="88" cy="93" r="4" fill="#ffffff"/>
    
    <!-- Connections -->
    <line x1="40" y1="35" x2="30" y2="64" stroke-width="1.5" opacity="0.7"/>
    <line x1="40" y1="35" x2="64" y2="64" stroke-width="1.5" opacity="0.7"/>
    <line x1="64" y1="25" x2="64" y2="64" stroke-width="2" opacity="0.8"/>
    <line x1="88" y1="35" x2="98" y2="64" stroke-width="1.5" opacity="0.7"/>
    <line x1="88" y1="35" x2="64" y2="64" stroke-width="1.5" opacity="0.7"/>
    
    <line x1="30" y1="64" x2="40" y2="93" stroke-width="1.5" opacity="0.7"/>
    <line x1="64" y1="64" x2="64" y2="103" stroke-width="2" opacity="0.8"/>
    <line x1="98" y1="64" x2="88" y2="93" stroke-width="1.5" opacity="0.7"/>
    <line x1="64" y1="64" x2="40" y2="93" stroke-width="1.5" opacity="0.7"/>
    <line x1="64" y1="64" x2="88" y2="93" stroke-width="1.5" opacity="0.7"/>
  </g>
  
  <!-- "N" letter overlay -->
  <path d="M45 45 L45 83 L55 83 L55 63 L73 83 L83 83 L83 45 L73 45 L73 65 L55 45 Z" 
        fill="#ffffff" opacity="0.8"/>
  
  <!-- Pulsing effect on central node -->
  <circle cx="64" cy="64" r="6" fill="#ffffff" opacity="0.5">
    <animate attributeName="r" values="6;8;6" dur="2s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0.5;0.8;0.5" dur="2s" repeatCount="indefinite"/>
  </circle>
</svg>
