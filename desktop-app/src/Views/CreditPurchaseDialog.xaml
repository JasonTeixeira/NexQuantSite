<Window x:Class="QuantumTrader.Views.CreditPurchaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="💳 Purchase Credits - Quantum Trader Professional"
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#0F1419"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/App.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="DarkBackground">#0F1419</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBackground">#1A2332</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBlue">#00D4FF</SolidColorBrush>
        <SolidColorBrush x:Key="AccentGreen">#00FF88</SolidColorBrush>
        <SolidColorBrush x:Key="AccentRed">#FF4757</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimary">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#8B949E</SolidColorBrush>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="💳 PURCHASE CREDITS" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Add credits to your account for AI strategy building and backtesting"
                           FontSize="14" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Credit Packages -->
                <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📦 CREDIT PACKAGES" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Starter Package -->
                            <Border Grid.Column="0" Grid.Row="0" Background="#2A2A2A" CornerRadius="6" Padding="15" Margin="0,0,5,10">
                                <StackPanel>
                                    <TextBlock Text="🚀 STARTER" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="$50.00" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="50 Credits" FontSize="14"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="• 10 AI Strategies" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="• 20 Backtests" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="• 16 Optimizations" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <Button Content="SELECT" Background="{StaticResource AccentGreen}"
                                            Foreground="Black" FontWeight="Bold" Padding="10,8" Margin="0,10,0,0"
                                            Click="StarterPackage_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Professional Package -->
                            <Border Grid.Column="1" Grid.Row="0" Background="#2A2A2A" CornerRadius="6" Padding="15" Margin="5,0,5,10"
                                    BorderBrush="{StaticResource AccentBlue}" BorderThickness="2">
                                <StackPanel>
                                    <TextBlock Text="⭐ POPULAR" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="PROFESSIONAL" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="$200.00" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="250 Credits" FontSize="14"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="• 50 AI Strategies" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="• 100 Backtests" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="• 83 Optimizations" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="+20% Bonus Credits" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <Button Content="SELECT" Background="{StaticResource AccentBlue}"
                                            Foreground="Black" FontWeight="Bold" Padding="10,8" Margin="0,10,0,0"
                                            Click="ProfessionalPackage_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Enterprise Package -->
                            <Border Grid.Column="2" Grid.Row="0" Background="#2A2A2A" CornerRadius="6" Padding="15" Margin="5,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="🏢 ENTERPRISE" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="$500.00" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="750 Credits" FontSize="14"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="• 150 AI Strategies" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="• 300 Backtests" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="• 250 Optimizations" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="+50% Bonus Credits" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <Button Content="SELECT" Background="{StaticResource AccentGreen}"
                                            Foreground="Black" FontWeight="Bold" Padding="10,8" Margin="0,10,0,0"
                                            Click="EnterprisePackage_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Custom Amount -->
                <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="💰 CUSTOM AMOUNT" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Amount ($)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBox x:Name="CustomAmountInput" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                         BorderBrush="#404040" Padding="10,8" FontSize="16" Text="100.00"
                                         TextChanged="CustomAmountInput_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,0,0">
                                <Button Content="ADD CREDITS" Background="{StaticResource AccentGreen}"
                                        Foreground="Black" FontWeight="Bold" Padding="15,8"
                                        Click="CustomAmount_Click"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="CustomAmountPreview" Text="You'll receive: 100 Credits"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Payment Methods -->
                <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="💳 PAYMENT METHODS" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <RadioButton x:Name="StripeRadio" Content="💳 Credit Card"
                                         Foreground="{StaticResource TextPrimary}" Margin="0,0,10,0" IsChecked="True"/>
                            <RadioButton x:Name="PayPalRadio" Content="📧 PayPal"
                                         Foreground="{StaticResource TextPrimary}" Grid.Column="1" Margin="10,0"/>
                            <RadioButton x:Name="CryptoRadio" Content="₿ Cryptocurrency"
                                         Foreground="{StaticResource TextPrimary}" Grid.Column="2" Margin="10,0,0,0"/>
                        </Grid>

                        <Border Background="#2A2A2A" CornerRadius="6" Padding="15" Margin="0,15,0,0">
                            <TextBlock Text="🔒 All payments are processed securely with 256-bit SSL encryption. Your payment information is never stored on our servers."
                                       FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Current Balance" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock x:Name="CurrentBalanceText" Text="$1,245.00" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentGreen}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="CANCEL" Background="Transparent"
                        Foreground="{StaticResource TextSecondary}" BorderBrush="#404040"
                        Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="PROCESS PAYMENT" Background="{StaticResource AccentGreen}"
                        Foreground="Black" FontWeight="Bold" Padding="20,10" Click="ProcessPayment_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
