<UserControl x:Class="QuantumTrader.Views.EnhancedLiveTradingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400">

    <Grid Background="{StaticResource NexusAIBackgroundPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Style="{StaticResource NexusCard}" Margin="16,16,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🏆" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ENTERPRISE MULTI-ACCOUNT TRADING"
                                   Style="{StaticResource NexusHeaderSmall}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Ultra-Professional Quant-Grade Platform"
                                   Style="{StaticResource NexusTextCaption}"
                                   Opacity="0.8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Global Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📊 GLOBAL ANALYTICS"
                            Style="{StaticResource NexusButtonPrimary}"
                            Margin="0,0,8,0"
                            Padding="12,8"
                            FontWeight="SemiBold"
                            Command="{Binding ViewGlobalAnalyticsCommand}"/>
                    <Button Content="⚙️ PORTFOLIO SETTINGS"
                            Style="{StaticResource NexusButtonSecondary}"
                            Margin="0,0,8,0"
                            Padding="12,8"
                            Command="{Binding ConfigurePortfolioCommand}"/>
                    <Button Content="🚨 EMERGENCY STOP ALL"
                            Style="{StaticResource NexusButtonError}"
                            Padding="12,8"
                            FontWeight="Bold"
                            Command="{Binding EmergencyStopAllCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Global Portfolio Metrics -->
        <Border Grid.Row="1" Style="{StaticResource NexusCard}" Margin="16,0,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Portfolio Value -->
                <StackPanel Grid.Column="0" Margin="16,12">
                    <TextBlock Text="💰 TOTAL PORTFOLIO" Style="{StaticResource NexusTextCaption}"/>
                    <TextBlock Text="{Binding TotalPortfolioValue, StringFormat={}${0:N2}}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource NexusAccentBrush}"/>
                </StackPanel>

                <!-- Total P&L -->
                <StackPanel Grid.Column="1" Margin="16,12">
                    <TextBlock Text="📈 TOTAL P&amp;L" Style="{StaticResource NexusTextCaption}"/>
                    <TextBlock Text="{Binding TotalPnL, StringFormat={}+${0:N2}}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource NexusSuccessBrush}"/>
                </StackPanel>

                <!-- Daily P&L -->
                <StackPanel Grid.Column="2" Margin="16,12">
                    <TextBlock Text="📊 DAILY P&amp;L" Style="{StaticResource NexusTextCaption}"/>
                    <TextBlock Text="{Binding DailyPnL, StringFormat={}+${0:N2}}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource NexusSuccessBrush}"/>
                </StackPanel>

                <!-- Active Accounts -->
                <StackPanel Grid.Column="3" Margin="16,12">
                    <TextBlock Text="🎯 ACTIVE ACCOUNTS" Style="{StaticResource NexusTextCaption}"/>
                    <TextBlock FontSize="24" FontWeight="Bold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                                <Binding Path="ActiveAccountCount"/>
                                <Binding Path="TotalAccountCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Win Rate -->
                <StackPanel Grid.Column="4" Margin="16,12">
                    <TextBlock Text="🏆 WIN RATE" Style="{StaticResource NexusTextCaption}"/>
                    <TextBlock Text="{Binding GlobalWinRate, StringFormat={}{0:F1}%}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource NexusInfoBrush}"/>
                </StackPanel>

                <!-- Global Sharpe -->
                <StackPanel Grid.Column="5" Margin="16,12">
                    <TextBlock Text="📉 SHARPE RATIO" Style="{StaticResource NexusTextCaption}"/>
                    <TextBlock Text="{Binding GlobalSharpeRatio, StringFormat={}{0:F2}}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource NexusInfoBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Multi-Account Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Accounts}" Margin="16,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource NexusCard}"
                                Margin="0,0,0,8"
                                Background="{StaticResource NexusBackgroundSecondary}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Account Header Row -->
                                <Grid Grid.Row="0" Margin="16,12,16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Account Status & Name -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding ConnectionStatusIcon}"
                                                   FontSize="20"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding ConnectionStatus}"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding StatusIcon}"
                                                   FontSize="20"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AccountName}"
                                                       FontSize="16"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding AccountType}"
                                                       Style="{StaticResource NexusTextCaption}"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Strategy Dropdown -->
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableStrategies}"
                                              SelectedItem="{Binding SelectedStrategy}"
                                              DisplayMemberPath="Name"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                <Setter Property="Background" Value="{StaticResource NexusBackgroundTertiary}"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>

                                    <!-- Risk Controls -->
                                    <Grid Grid.Column="2" Margin="0,0,8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="MIN:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0"
                                                   FontSize="11"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding MinContracts}"
                                                 Width="40"
                                                 TextAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>

                                        <TextBlock Grid.Column="2" Text="MAX:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0"
                                                   FontSize="11"/>
                                        <TextBox Grid.Column="3"
                                                 Text="{Binding MaxContracts}"
                                                 Width="40"
                                                 TextAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Risk Percentage -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="RISK:" Margin="0,0,4,0" FontSize="11"/>
                                        <Slider Width="80"
                                                Minimum="0.5" Maximum="10"
                                                Value="{Binding RiskPercentage}"
                                                TickFrequency="0.5"
                                                IsSnapToTickEnabled="True"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding RiskPercentage, StringFormat={}{0:F1}%}"
                                                   Width="40"
                                                   FontWeight="SemiBold"
                                                   Margin="4,0,0,0"/>
                                    </StackPanel>

                                    <!-- Account Balance & P&L -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="BALANCE" FontSize="10" Opacity="0.7"/>
                                            <TextBlock Text="{Binding Balance, StringFormat={}${0:N0}}"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="P&amp;L" FontSize="10" Opacity="0.7"/>
                                            <TextBlock Text="{Binding CurrentPnLFormatted}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource NexusSuccessBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Metrics Display -->
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource NexusBackgroundTertiary}"
                                                CornerRadius="4" Padding="8,4" Margin="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="WIN" FontSize="10" Opacity="0.7" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding WinRateFormatted}"
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource NexusBackgroundTertiary}"
                                                CornerRadius="4" Padding="8,4" Margin="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="SHARPE" FontSize="10" Opacity="0.7" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding SharpeRatioFormatted}"
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource NexusBackgroundTertiary}"
                                                CornerRadius="4" Padding="8,4">
                                            <StackPanel>
                                                <TextBlock Text="DD" FontSize="10" Opacity="0.7" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding MaxDrawdownFormatted}"
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Account Controls -->
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="▶️"
                                                Style="{StaticResource NexusButtonSuccess}"
                                                Command="{Binding StartAccountCommand}"
                                                Width="32" Height="32"
                                                Margin="0,0,4,0"
                                                ToolTip="Start Trading"
                                                IsEnabled="{Binding CanStart}"/>
                                        <Button Content="⏸️"
                                                Style="{StaticResource NexusButtonSecondary}"
                                                Command="{Binding PauseAccountCommand}"
                                                Width="32" Height="32"
                                                Margin="0,0,4,0"
                                                ToolTip="Pause Trading"/>
                                        <Button Content="⏹️"
                                                Style="{StaticResource NexusButtonSecondary}"
                                                Command="{Binding StopAccountCommand}"
                                                Width="32" Height="32"
                                                Margin="0,0,4,0"
                                                ToolTip="Stop Trading"/>
                                        <Button Content="🚨"
                                                Style="{StaticResource NexusButtonError}"
                                                Command="{Binding EmergencyStopCommand}"
                                                Width="32" Height="32"
                                                Margin="0,0,4,0"
                                                ToolTip="Emergency Stop"/>
                                        <Button Content="⚙️"
                                                Style="{StaticResource NexusButtonSecondary}"
                                                Command="{Binding ConfigureAccountCommand}"
                                                Width="32" Height="32"
                                                Margin="0,0,4,0"
                                                ToolTip="Configure Account"/>
                                        <Button Content="📊"
                                                Style="{StaticResource NexusButtonInfo}"
                                                Command="{Binding ViewDetailsCommand}"
                                                Width="32" Height="32"
                                                ToolTip="View Analytics"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Expanded Risk Controls (Collapsible) -->
                                <Expander Grid.Row="1" Header="Advanced Risk Controls" Margin="16,0,16,8">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Stop Loss / Take Profit -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="STOP LOSS %" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                                            <Slider Value="{Binding StopLoss}"
                                                    Minimum="0.5" Maximum="5"
                                                    TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"/>
                                            <TextBlock Text="{Binding StopLoss, StringFormat={}{0:F1}%}"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Text="TAKE PROFIT %" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                                            <Slider Value="{Binding TakeProfit}"
                                                    Minimum="1" Maximum="10"
                                                    TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"/>
                                            <TextBlock Text="{Binding TakeProfit, StringFormat={}{0:F1}%}"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- Position Sizing Method -->
                                        <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                            <TextBlock Text="POSITION SIZING" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding PositionSizingMethods}"
                                                      SelectedItem="{Binding PositionSizingMethod}"
                                                      FontSize="12"/>
                                            <CheckBox Content="Dynamic Sizing"
                                                      IsChecked="{Binding IsDynamicSizingEnabled}"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- Apply Settings -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <Button Content="APPLY RISK SETTINGS"
                                                    Style="{StaticResource NexusButtonPrimary}"
                                                    Command="{Binding ApplyRiskSettingsCommand}"
                                                    Padding="12,8"
                                                    FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding RiskLevel}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"
                                                       FontWeight="Bold"
                                                       Opacity="0.8"/>
                                        </StackPanel>
                                    </Grid>
                                </Expander>

                                <!-- Real-time Mini Chart (Optional) -->
                                <Border Grid.Row="2"
                                        Height="60"
                                        Margin="16,0,16,12"
                                        Background="{StaticResource NexusBackgroundTertiary}"
                                        CornerRadius="4">
                                    <Grid>
                                        <!-- Placeholder for real-time P&amp;L chart -->
                                        <TextBlock Text="📈 Real-time P&amp;L Chart"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.5"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer with Add Account Button -->
        <Border Grid.Row="3" Style="{StaticResource NexusCard}" Margin="16,8,16,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📊" FontSize="20" Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Managing {0} accounts | {1} active | ${2:N0} total value">
                                <Binding Path="TotalAccountCount"/>
                                <Binding Path="ActiveAccountCount"/>
                                <Binding Path="TotalPortfolioValue"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ ADD LIVE ACCOUNT"
                            Style="{StaticResource NexusButtonPrimary}"
                            Margin="0,0,8,0"
                            Padding="16,8"
                            FontWeight="Bold"
                            Command="{Binding AddLiveAccountCommand}"/>
                    <Button Content="➕ ADD SIM ACCOUNT"
                            Style="{StaticResource NexusButtonSecondary}"
                            Padding="16,8"
                            FontWeight="Bold"
                            Command="{Binding AddSimAccountCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
