                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,0">
                                    <TextBlock Text="Creativity" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                    <Slider x:Name="CreativitySlider" Minimum="0" Maximum="1" Value="0.5"
