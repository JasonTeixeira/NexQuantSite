<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="chartGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.6" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="#1a1a2e"/>
  
  <!-- Chart lines -->
  <path d="M20 200 L80 150 L140 180 L200 120 L260 160 L320 100 L380 140" 
        stroke="#3b82f6" stroke-width="3" fill="none"/>
  
  <!-- Volume bars -->
  <rect x="20" y="220" width="6" height="60" fill="#06b6d4" opacity="0.6"/>
  <rect x="80" y="240" width="6" height="40" fill="#06b6d4" opacity="0.6"/>
  <rect x="140" y="230" width="6" height="50" fill="#06b6d4" opacity="0.6"/>
  <rect x="200" y="250" width="6" height="30" fill="#06b6d4" opacity="0.6"/>
  <rect x="260" y="235" width="6" height="45" fill="#06b6d4" opacity="0.6"/>
  <rect x="320" y="260" width="6" height="20" fill="#06b6d4" opacity="0.6"/>
  
  <!-- Grid lines -->
  <line x1="20" y1="80" x2="380" y2="80" stroke="#333" opacity="0.3"/>
  <line x1="20" y1="160" x2="380" y2="160" stroke="#333" opacity="0.3"/>
  <line x1="20" y1="240" x2="380" y2="240" stroke="#333" opacity="0.3"/>
  
  <!-- Candlesticks -->
  <g transform="translate(350, 120)">
    <rect x="-2" y="0" width="4" height="20" fill="#10b981"/>
    <line x1="0" y1="-10" x2="0" y2="30" stroke="#10b981" stroke-width="1"/>
  </g>
  
  <!-- Text overlay -->
  <text x="200" y="50" text-anchor="middle" fill="#e5e7eb" font-family="Arial" font-size="18" font-weight="bold">Financial Chart Analysis</text>
  <text x="200" y="290" text-anchor="middle" fill="#9ca3af" font-family="Arial" font-size="12">Market Data Visualization</text>
</svg>
