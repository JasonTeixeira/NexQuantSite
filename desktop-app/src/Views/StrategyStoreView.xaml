<UserControl x:Class="QuantumTrader.Views.StrategyStoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Professional Store Header -->
        <Border Grid.Row="0"
                Background="#1A1A25"
                BorderBrush="#2A2A3E"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🛒 STRATEGY MARKETPLACE"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Professional trading strategies from verified developers worldwide"
                               Foreground="#A0A0B8"
                               FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💎 Upgrade Plan"
                            Style="{StaticResource NexusButton}"
                            Background="#FFD700"
                            Foreground="Black"
                            Margin="0,0,12,0"/>
                    <Button Content="📦 My Strategies"
                            Style="{StaticResource NexusButton}"
                            Background="#00BBFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Store Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Categories Grid -->
                <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🏷️ BROWSE BY CATEGORY"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="200"
                                            Height="100"
                                            Background="#2A2A3E"
                                            CornerRadius="8"
                                            BorderBrush="#3A3A4E"
                                            BorderThickness="1"
                                            Margin="0,0,16,16"
                                            Cursor="Hand">
                                        <Grid Margin="16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="14"/>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       Foreground="#B0B0C8"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,8"/>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding StrategyCount, StringFormat='{}{0} strategies'}"
                                                       Foreground="#00BBFF"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Featured Strategies -->
                <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="⭐ FEATURED STRATEGIES"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding FeaturedStrategies}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="360"
                                            Height="320"
                                            Background="#1A1A25"
                                            CornerRadius="12"
                                            BorderBrush="#2A2A3E"
                                            BorderThickness="1"
                                            Margin="0,0,20,20"
                                            Cursor="Hand">
                                        <Grid Margin="20">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header with badges -->
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="16"/>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Border Background="#FFD700"
                                                            CornerRadius="10"
                                                            Padding="6,2"
                                                            Margin="0,0,4,0"
                                                            Visibility="{Binding IsBestseller, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="🏆 BESTSELLER"
                                                                   Foreground="Black"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"/>
                                                    </Border>

                                                    <Border Background="#00FF7F"
                                                            CornerRadius="10"
                                                            Padding="6,2"
                                                            Margin="0,0,4,0"
                                                            Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="🆕 NEW"
                                                                   Foreground="Black"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Author and Price -->
                                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Author}"
                                                           Foreground="#00BBFF"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding PriceFormatted}"
                                                           Foreground="#FFD700"
                                                           FontSize="16"
                                                           FontWeight="Bold"/>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Description}"
                                                       Foreground="#B0B0C8"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Margin="0,0,0,12"/>

                                            <!-- Performance Metrics -->
                                            <Grid Grid.Row="3" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="RETURN" Style="{StaticResource NexusTextCaption}"/>
                                                    <TextBlock Text="{Binding LiveReturnFormatted}"
                                                               Foreground="Green"
                                                               FontWeight="Bold"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="SHARPE" Style="{StaticResource NexusTextCaption}"/>
                                                    <TextBlock Text="{Binding SharpeRatioFormatted}"
                                                               Foreground="#00BBFF"
                                                               FontWeight="Bold"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="WIN RATE" Style="{StaticResource NexusTextCaption}"/>
                                                    <TextBlock Text="{Binding WinRateFormatted}"
                                                               Foreground="Orange"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Rating and Actions -->
                                            <Grid Grid.Row="4" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding RatingFormatted}"
                                                               Foreground="White"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding DownloadsFormatted}"
                                                               Foreground="#888"
                                                               FontSize="10"
                                                               Margin="12,0,0,0"/>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Background="{Binding ComplexityColor}"
                                                        CornerRadius="8"
                                                        Padding="6,2">
                                                    <TextBlock Text="{Binding Complexity}"
                                                               Foreground="White"
                                                               FontSize="9"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </Grid>

                                            <!-- Purchase Button -->
                                            <Grid Grid.Row="5">
                                                <Button Content="💳 PURCHASE"
                                                        Style="{StaticResource NexusButton}"
                                                        Background="#00BBFF"
                                                        HorizontalAlignment="Stretch"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Loading Indicator -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center"
                            Margin="0,40,0,0">
                    <ProgressBar IsIndeterminate="True"
                                 Width="200"
                                 Height="6"
                                 Foreground="#00BBFF"/>
                    <TextBlock Text="Loading strategies..."
                               Foreground="#888"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
