                                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}" Margin="5,0"/>
                                <TextBlock Text="GPU: RTX 4090" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>

