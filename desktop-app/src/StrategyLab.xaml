<Window x:Class="QuantumTrader.StrategyLab"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧠 Elite Trading ML - AI-Powered Strategy Lab"
        Height="1000" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#0F1419">

    <Window.Resources>
        <SolidColorBrush x:Key="DarkBackground">#0F1419</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBackground">#1A2332</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBlue">#00D4FF</SolidColorBrush>
        <SolidColorBrush x:Key="AccentGreen">#00FF88</SolidColorBrush>
        <SolidColorBrush x:Key="AccentRed">#FF4757</SolidColorBrush>
        <SolidColorBrush x:Key="AccentOrange">#FFA500</SolidColorBrush>
        <SolidColorBrush x:Key="AccentPurple">#9B59B6</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimary">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#8B949E</SolidColorBrush>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="#404040" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🧠" FontSize="32" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="AI-POWERED STRATEGY LAB" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}"/>
                        <TextBlock Text="World-Class Quant Strategy Development Platform" FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- AI Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentGreen}" Margin="5,0"/>
                    <TextBlock Text="AI Models: Active" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>

                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentBlue}" Margin="15,0,5,0"/>
                    <TextBlock Text="Backend: Connected" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>

                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentPurple}" Margin="15,0,5,0"/>
                    <TextBlock Text="GPU: Available" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>

                <!-- Quick Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="🚀 NEW STRATEGY" Background="{StaticResource AccentGreen}"
                            Foreground="Black" FontWeight="Bold" Padding="12,6" Margin="0,0,10,0"/>
                    <Button Content="📊 BACKTEST" Background="{StaticResource AccentBlue}"
                            Foreground="Black" FontWeight="Bold" Padding="12,6" Margin="0,0,10,0"/>
                    <Button Content="🤖 AI ASSIST" Background="{StaticResource AccentOrange}"
                            Foreground="Black" FontWeight="Bold" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Strategy Builder -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="#404040" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="🔧 STRATEGY BUILDER" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,25"/>

                        <!-- Strategy Name -->
                        <TextBlock Text="Strategy Name" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                        <TextBox x:Name="StrategyNameInput" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
