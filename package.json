{
  "name": "nexural-trading-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3060",
    "lint": "next lint",
    "start": "next start",
    "db:migrate": "psql -d $DATABASE_URL -f lib/database/schema.sql",
    "db:seed": "tsx lib/database/seed.ts",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "test:db": "tsx lib/database/test-connection.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true next build && echo \"Bundle analysis complete - check .next/analyze/\"",
    "clean": "rm -rf .next out",
    "clean:all": "rm -rf .next out node_modules",
    "reinstall": "npm run clean:all && npm install",
    "perf:build": "npm run clean && time npm run build",
    "perf:analyze": "npm run analyze",
    "test:sre": "node scripts/run-all-tests.js",
    "test:smoke": "node -e \"require('./scripts/run-all-tests.js').runSmokeTests()\"",
    "test:load": "node -e \"require('./scripts/run-all-tests.js').runLoadTests()\"",
    "test:buttons": "node -e \"require('./scripts/run-all-tests.js').runButtonTests()\"",
    "test:stress": "npm run test:sre",
    "test:chaos": "node -e \"const {ChaosTestRunner, DEFAULT_CHAOS_CONFIG} = require('./lib/testing/chaos-test'); new ChaosTestRunner(DEFAULT_CHAOS_CONFIG).runChaosTests().catch(console.error)\"",
    "health:check": "curl -s http://localhost:3060/api/health | jq .",
    "monitor:circuit": "curl -s http://localhost:3060/api/circuit-breaker | jq .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:security": "playwright test --grep=\"Security Tests\"",
    "test:lighthouse": "lhci autorun",
    "audit:security": "npm audit --audit-level=moderate",
    "test:all": "npm test && npm run test:e2e && npm run test:security",
    "fix:security": "node scripts/auto-fix-security.js",
    "check:security": "node scripts/security-check.js",
    "generate:secrets": "node scripts/generate-secrets.js"
  },
