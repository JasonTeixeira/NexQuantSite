                            <ComboBoxItem Content="📈 Momentum"/>
                            <ComboBoxItem Content="⚡ Scalping"/>
                            <ComboBoxItem Content="🛡️ Arbitrage"/>
                            <ComboBoxItem Content="🧠 ML-Based"/>
                            <ComboBoxItem Content="🔮 Sentiment"/>
                            <ComboBoxItem Content="📊 Statistical Arbitrage"/>
                            <ComboBoxItem Content="🎲 Custom"/>
                            <ComboBoxItem Content="🌊 Wave Analysis"/>
                            <ComboBoxItem Content="🔍 Pattern Recognition"/>
                        </ComboBox>

                        <!-- Instruments -->
                        <TextBlock Text="💰 TRADING INSTRUMENTS" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <ListBox x:Name="InstrumentSelector" Height="120" Background="#2A2A2A"
                                 Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20">
                            <ListBoxItem Content="ES - E-mini S&amp;P 500" IsSelected="True"/>
                            <ListBoxItem Content="NQ - E-mini NASDAQ-100"/>
                            <ListBoxItem Content="YM - E-mini Dow"/>
                            <ListBoxItem Content="RTY - E-mini Russell 2000"/>
                            <ListBoxItem Content="CL - Crude Oil"/>
                            <ListBoxItem Content="GC - Gold"/>
                            <ListBoxItem Content="ZB - 30-Year Treasury"/>
                            <ListBoxItem Content="6E - Euro FX"/>
                            <ListBoxItem Content="BTC - Bitcoin"/>
                            <ListBoxItem Content="ETH - Ethereum"/>
                        </ListBox>

                        <!-- Timeframe -->
                        <TextBlock Text="⏰ TIMEFRAME" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <ComboBox x:Name="TimeframeSelector" Margin="0,0,0,20"
                                  Background="#2A2A2A" Foreground="{StaticResource TextPrimary}" Padding="10,8">
                            <ComboBoxItem Content="1 minute"/>
                            <ComboBoxItem Content="5 minutes"/>
                            <ComboBoxItem Content="15 minutes"/>
                            <ComboBoxItem Content="1 hour"/>
                            <ComboBoxItem Content="4 hours"/>
                            <ComboBoxItem Content="1 day"/>
                        </ComboBox>

                        <!-- Risk Settings -->
                        <TextBlock Text="🛡️ RISK SETTINGS" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Max Position Size (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <Slider x:Name="MaxPositionSlider" Minimum="1" Maximum="20" Value="5"
