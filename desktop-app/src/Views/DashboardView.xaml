<UserControl x:Class="QuantumTrader.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Portfolio Performance Overview -->
            <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📊 PORTFOLIO PERFORMANCE OVERVIEW"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,16"/>

                    <!-- Performance Metrics Grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Today -->
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="TODAY" Style="{StaticResource NexusTextCaption}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PortfolioSummary.DailyPnLFormatted}"
                                       Foreground="{Binding PortfolioSummary.DailyPnLColor}"
                                       Style="{StaticResource NexusTextValue}"
                                       HorizontalAlignment="Center"
                                       FontSize="20"/>
                            <TextBlock Text="+1.32%"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextCaption}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Week -->
                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock Text="WEEK" Style="{StaticResource NexusTextCaption}" HorizontalAlignment="Center"/>
                            <TextBlock Text="+$8,750"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextValue}"
                                       HorizontalAlignment="Center"
                                       FontSize="20"/>
                            <TextBlock Text="+4.89%"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextCaption}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Month -->
                        <StackPanel Grid.Column="2" Margin="0,0,16,0">
                            <TextBlock Text="MONTH" Style="{StaticResource NexusTextCaption}" HorizontalAlignment="Center"/>
                            <TextBlock Text="+$23,450"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextValue}"
                                       HorizontalAlignment="Center"
                                       FontSize="20"/>
                            <TextBlock Text="+6.97%"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextCaption}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Sharpe Ratio -->
                        <StackPanel Grid.Column="3" Margin="0,0,16,0">
                            <TextBlock Text="SHARPE RATIO" Style="{StaticResource NexusTextCaption}" HorizontalAlignment="Center"/>
                            <TextBlock Text="2.34"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextValue}"
                                       HorizontalAlignment="Center"
                                       FontSize="20"/>
                            <TextBlock Text="Excellent"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextCaption}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Win Rate -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="WIN RATE" Style="{StaticResource NexusTextCaption}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PortfolioSummary.WinRateFormatted}"
                                       Foreground="{Binding PortfolioSummary.WinRateColor}"
                                       Style="{StaticResource NexusTextValue}"
                                       HorizontalAlignment="Center"
                                       FontSize="20"/>
                            <TextBlock Text="Strong"
                                       Foreground="Green"
                                       Style="{StaticResource NexusTextCaption}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Strategy Performance Analysis -->
            <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🤖 STRATEGY PERFORMANCE ANALYSIS"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,16"/>

                    <!-- Strategy Performance Table -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <!-- Headers -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Strategy" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Return" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Sharpe" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Max DD" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Win Rate" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Trades" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="Status" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>

                        <!-- Momentum Scalper -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Momentum Scalper" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="34.5%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="2.8" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="12.3%" Foreground="Orange" Padding="8"/>
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="68.5%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="1" Grid.Column="5" Text="1,247" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="1" Grid.Column="6" Text="🟢 Active" Foreground="Green" Padding="8"/>

                        <!-- Mean Reversion Pro -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mean Reversion Pro" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="28.7%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="2.1" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="8.9%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="72.3%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="2" Grid.Column="5" Text="892" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="2" Grid.Column="6" Text="🟢 Active" Foreground="Green" Padding="8"/>

                        <!-- Breakout Hunter -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Breakout Hunter" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="45.2%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="1.9" Foreground="Orange" Padding="8"/>
                        <TextBlock Grid.Row="3" Grid.Column="3" Text="18.7%" Foreground="Red" Padding="8"/>
                        <TextBlock Grid.Row="3" Grid.Column="4" Text="58.9%" Foreground="Orange" Padding="8"/>
                        <TextBlock Grid.Row="3" Grid.Column="5" Text="567" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="3" Grid.Column="6" Text="🟢 Active" Foreground="Green" Padding="8"/>

                        <!-- Smart Grid Pro -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Smart Grid Pro" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="19.8%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="3.2" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="4" Grid.Column="3" Text="6.1%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="4" Grid.Column="4" Text="89.1%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="4" Grid.Column="5" Text="2,341" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="4" Grid.Column="6" Text="🟢 Active" Foreground="Green" Padding="8"/>

                        <!-- Event Catalyst -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Event Catalyst" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="52.3%" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="2.4" Foreground="Green" Padding="8"/>
                        <TextBlock Grid.Row="5" Grid.Column="3" Text="22.1%" Foreground="Red" Padding="8"/>
                        <TextBlock Grid.Row="5" Grid.Column="4" Text="61.4%" Foreground="Orange" Padding="8"/>
                        <TextBlock Grid.Row="5" Grid.Column="5" Text="234" Foreground="White" Padding="8"/>
                        <TextBlock Grid.Row="5" Grid.Column="6" Text="🟡 Paused" Foreground="Orange" Padding="8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Risk Management Dashboard -->
            <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚖️ RISK MANAGEMENT DASHBOARD"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Risk Metrics -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <!-- Portfolio VaR -->
                            <Border Background="#0F0F1A" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Portfolio VaR (95%)" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="$12,450" Foreground="Green" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Low" Foreground="Green" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Max Drawdown -->
                            <Border Background="#0F0F1A" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Maximum Drawdown" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="8.7%" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Acceptable" Foreground="Orange" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Concentration Risk -->
                            <Border Background="#0F0F1A" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Concentration Risk" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="23%" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Medium" Foreground="Orange" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Strategy Correlation -->
                            <Border Background="#0F0F1A" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Strategy Correlation" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="0.34" Foreground="Green" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Low" Foreground="Green" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Volatility -->
                            <Border Background="#0F0F1A" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Volatility (30D)" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="18.2%" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Medium" Foreground="Orange" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Portfolio Risk Score -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="PORTFOLIO RISK"
                                       Style="{StaticResource NexusTextCaption}"
                                       HorizontalAlignment="Center"/>
                            <Border Width="120" Height="120"
                                    CornerRadius="60"
                                    BorderBrush="Orange"
                                    BorderThickness="8"
                                    Background="#0F0F1A">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="34/100"
                                               Foreground="Orange"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="RISK SCORE"
                                               Style="{StaticResource NexusTextCaption}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Account Health Monitor -->
            <Border Style="{StaticResource NexusCard}">
                <StackPanel>
                    <TextBlock Text="🏥 ACCOUNT HEALTH MONITOR"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,16"/>

                    <!-- Account Health Grid - Uses Live Trading Data -->
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A25"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8"
                                        BorderBrush="#2A2A3E"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Account Info -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Type}"
                                                       FontSize="10"
                                                       Foreground="#A0A0B8"/>
                                        </StackPanel>

                                        <!-- Health Score -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Health"
                                                       Style="{StaticResource NexusTextCaption}"/>
                                            <TextBlock Text="87/100"
                                                       Foreground="Green"
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Balance -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Balance"
                                                       Style="{StaticResource NexusTextCaption}"/>
                                            <TextBlock Text="{Binding Balance, StringFormat='${0:N0}'}"
                                                       Foreground="White"
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- P&L -->
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="P&amp;L"
                                                       Style="{StaticResource NexusTextCaption}"/>
                                            <TextBlock Text="{Binding PnLFormatted}"
                                                       Foreground="{Binding PnLColor}"
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Risk -->
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Risk Use"
                                                       Style="{StaticResource NexusTextCaption}"/>
                                            <TextBlock Text="23%"
                                                       Foreground="Green"
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Strategy -->
                                        <StackPanel Grid.Column="5">
                                            <TextBlock Text="Strategy"
                                                       Style="{StaticResource NexusTextCaption}"/>
                                            <TextBlock Text="{Binding AssignedStrategy}"
                                                       Foreground="#00BBFF"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- Status -->
                                        <StackPanel Grid.Column="6">
                                            <TextBlock Text="Status"
                                                       Style="{StaticResource NexusTextCaption}"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
