<UserControl x:Class="QuantumTrader.Views.ControlCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Strategy Selection & Account Management -->
        <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                CornerRadius="8" Margin="0,0,5,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Built-in Strategies Section -->
                    <TextBlock Text="Built-in Strategies (5)" FontSize="16" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                    <ComboBox x:Name="StrategySelector" Background="{StaticResource PanelBackground}"
                             Foreground="{StaticResource TextPrimary}" BorderBrush="#404040" Margin="0,0,0,15">
                        <ComboBoxItem Content="🎯 Mean Reversion Pro" IsSelected="True"/>
                        <ComboBoxItem Content="📈 Momentum Scalper"/>
                        <ComboBoxItem Content="⚡ Breakout Hunter"/>
                        <ComboBoxItem Content="🔄 Arbitrage Engine"/>
                        <ComboBoxItem Content="🧠 Neural Ensemble"/>
                    </ComboBox>

                    <!-- Strategy Status -->
                    <Border Background="#1E3A5F" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Strategy Status" FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="StrategyStatus" Text="⏸️ Paused (3 accounts)"
                                      Foreground="{StaticResource AccentGreen}" FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- Account Assignment -->
                    <TextBlock Text="Account Assignment" FontSize="14" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                    <ListView x:Name="AccountsListView" Background="Transparent"
                             BorderThickness="0" Foreground="{StaticResource TextPrimary}" Height="200" Margin="0,0,0,15">
                        <!-- Populated programmatically -->
                    </ListView>

                    <!-- Master Controls -->
                    <Separator Background="#404040" Margin="0,10,0,20"/>
                    <TextBlock Text="Master Controls" FontSize="16" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                    <Button Content="🔴 FLATTEN ALL POSITIONS" Background="{StaticResource AccentRed}"
                           Style="{StaticResource ModernButton}" Margin="0,0,0,10" Click="FlattenAll_Click"/>
                    <Button Content="⏸️ PAUSE ALL STRATEGIES" Background="#FF8800"
                           Style="{StaticResource ModernButton}" Margin="0,0,0,10" Click="PauseAll_Click"/>
                    <TextBlock Text="Symbols &amp; Risk Controls" FontSize="14" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,10,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                        <TextBlock Text="Use Micros" Width="120" Foreground="{StaticResource TextSecondary}"/>
                        <CheckBox IsChecked="{Binding UseMicros}"/>
                    </StackPanel>
                    <TextBlock Text="Monitor Symbols" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="SymbolInput" Width="80" Style="{StaticResource ModernTextBox}" Text="ES"/>
                            <Button Content="Add" Margin="6,0,0,0" Click="AddSymbol_Click"/>
                            <Button Content="Remove Selected" Margin="6,0,0,0" Click="RemoveSymbol_Click"/>
                        </StackPanel>
                        <ListBox x:Name="SymbolListBox" ItemsSource="{Binding MonitoredSymbols}" Height="80">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimary}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBlock Text="Max Daily Loss" Width="120" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding Risk.MaxDailyLoss}" Width="100" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBlock Text="Risk/Trade %" Width="120" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding Risk.RiskPerTradePercent}" Width="100" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBlock Text="Contracts (min-max)" Width="120" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding Risk.MinContracts}" Width="50" Style="{StaticResource ModernTextBox}"/>
                            <TextBlock Text="-" Foreground="{StaticResource TextSecondary}" Margin="6,0,6,0"/>
                            <TextBox Text="{Binding Risk.MaxContracts}" Width="50" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                            <TextBlock Text="Confidence (L/H)" Width="120" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding Risk.ConfidenceLow}" Width="50" Style="{StaticResource ModernTextBox}"/>
                            <TextBlock Text="-" Foreground="{StaticResource TextSecondary}" Margin="6,0,6,0"/>
                            <TextBox Text="{Binding Risk.ConfidenceHigh}" Width="50" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#404040" Margin="0,10,0,10"/>
                    <Button Content="💾 Save Risk Settings" Style="{StaticResource ModernButton}" Click="SaveRiskLimits_Click"/>

                    <!-- Safety Controls -->
                    <TextBlock Text="Safety Controls" FontSize="14" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,10,0,6"/>
                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="ToggleKillSwitchBtn" Content="🛑 Toggle Global Kill Switch" Style="{StaticResource ModernButton}" Click="ToggleKillSwitch_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="CancelAllOrdersBtn" Content="🧹 Cancel All Orders" Style="{StaticResource ModernButton}" Click="CancelAllOrders_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="KillSwitchStatus" Text="Kill Switch: Unknown" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <TextBlock Text="Risk Lock Status" FontSize="14" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,10,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="RiskAccountInput" Width="120" Style="{StaticResource ModernTextBox}"/>
                        <Button Content="Check" Margin="6,0,0,0" Click="CheckRiskLock_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="RiskLockStatusText" Text="" Foreground="{StaticResource TextSecondary}"/>

                    <Separator Background="#404040" Margin="0,10,0,10"/>
                    <TextBlock Text="Diagnostics" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Account:" Foreground="{StaticResource TextSecondary}" Width="110"/>
                            <ComboBox x:Name="AccountFilter" Width="140">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Filter (symbol):" Foreground="{StaticResource TextSecondary}" Width="110"/>
                            <TextBox x:Name="SymbolFilter" Width="120" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <TextBlock x:Name="ReconHealthyText" Text="Recon: Unknown" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock x:Name="ReconLastRunText" Text="Last Run: -" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock x:Name="ReconUpdatesText" Text="Updates: -" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock x:Name="ReconPositionsText" Text="Positions: -" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock x:Name="ReconLastErrorText" Text="Last Error: -" Foreground="{StaticResource TextSecondary}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Refresh Diagnostics" Click="RefreshDiagnostics_Click"/>
                            <Button Content="Report Issue (Test)" Margin="6,0,0,0" Click="ReportIssue_Click"/>
                        </StackPanel>
                        <TextBlock Text="Recent Audit Events" FontWeight="Bold" Margin="0,8,0,4" Foreground="{StaticResource TextPrimary}"/>
                        <ListBox x:Name="AuditEventsList" Height="120"/>
                        <TextBlock Text="Positions (from broker)" FontWeight="Bold" Margin="0,8,0,4" Foreground="{StaticResource TextPrimary}"/>
                        <ListBox x:Name="BrokerPositionsList" Height="120"/>
                        <TextBlock Text="Open Orders" FontWeight="Bold" Margin="0,8,0,4" Foreground="{StaticResource TextPrimary}"/>
                        <ItemsControl x:Name="OpenOrdersControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0A0F14" CornerRadius="6" Padding="8" Margin="4" Width="Auto">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Symbol}" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Side:" Foreground="{StaticResource TextSecondary}" Width="60"/>
                                                <TextBlock Text="{Binding Side}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Qty:" Foreground="{StaticResource TextSecondary}" Width="60"/>
                                                <TextBlock Text="{Binding Quantity}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Status:" Foreground="{StaticResource TextSecondary}" Width="60"/>
                                                <TextBlock Text="{Binding Status}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="BrokerId:" Foreground="{StaticResource TextSecondary}" Width="60"/>
                                                <TextBlock Text="{Binding Id}"/>
                                            </StackPanel>
                                            <Button Content="Cancel Order" Style="{StaticResource ModernButton}" CommandParameter="{Binding}" Click="CancelOrder_Click"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Button Content="▶️ START SELECTED STRATEGY" Background="{StaticResource AccentGreen}"
                           Style="{StaticResource ModernButton}" Margin="0,0,0,10" Click="StartStrategy_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Center Panel - Watchlist & Live Positions -->
        <Border Grid.Column="1" Background="{StaticResource PanelBackground}"
                CornerRadius="8" Margin="5,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- KPI Header -->
                <TextBlock Grid.Row="0" Text="Live Metrics" FontSize="18" FontWeight="Bold"
                          Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                <!-- KPI Row: P&L / WinRate / Sharpe / MaxDD / Orders/min -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="P&amp;L Today" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="KpiPnlToday" Text="-" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Win Rate" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="KpiWinRate" Text="-" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Sharpe" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="KpiSharpe" Text="-" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Max DD" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="KpiMaxDd" Text="-" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentRed}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Orders/min" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="KpiOrdersPerMin" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Imbalance Meters -->
                <TextBlock Grid.Row="2" Text="Order Flow Imbalance (ES / NQ / YM / RTY)" FontSize="16" FontWeight="Bold"
                          Foreground="{StaticResource TextPrimary}" Margin="0,16,0,8"/>
                <Grid Grid.Row="2" Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="ES" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="EsMeter" Text="-" Foreground="{StaticResource AccentGreen}" FontSize="18" FontWeight="Bold"/>
                            <TextBlock x:Name="EsBuySell" Text="-" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="NQ" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="NqMeter" Text="-" Foreground="{StaticResource AccentGreen}" FontSize="18" FontWeight="Bold"/>
                            <TextBlock x:Name="NqBuySell" Text="-" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="YM" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="YmMeter" Text="-" Foreground="{StaticResource AccentGreen}" FontSize="18" FontWeight="Bold"/>
                            <TextBlock x:Name="YmBuySell" Text="-" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#0A0F14" CornerRadius="6" Padding="12" Margin="5">
                        <StackPanel>
                            <TextBlock Text="RTY" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="RtyMeter" Text="-" Foreground="{StaticResource AccentGreen}" FontSize="18" FontWeight="Bold"/>
                            <TextBlock x:Name="RtyBuySell" Text="-" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Live Positions Header -->
                <TextBlock Grid.Row="3" Text="Live Positions" FontSize="18" FontWeight="Bold"
                          Foreground="{StaticResource TextPrimary}" Margin="0,20,0,15"/>

                <!-- Live Positions Grid from broker -->
                <ItemsControl Grid.Row="4" x:Name="BrokerPositionsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0A0F14" CornerRadius="6" Padding="12" Margin="6" Width="230">
                                <StackPanel>
                                    <TextBlock Text="{Binding Symbol}" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Quantity:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                        <TextBlock Text="{Binding Quantity}" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Avg Price:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                        <TextBlock Text="{Binding AveragePrice, StringFormat=C2}" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="PnL:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                        <TextBlock Text="{Binding UnrealizedPnL, StringFormat=C0}" Foreground="{StaticResource AccentGreen}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Cancel" Style="{StaticResource ModernButton}" CommandParameter="{Binding}" Click="CancelPosition_Click"/>
                                        <Button Content="Flatten" Style="{StaticResource ModernButton}" Margin="6,0,0,0" CommandParameter="{Binding}" Click="FlattenPosition_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Right Panel - Portfolio Summary & Performance -->
        <Border Grid.Column="2" Background="{StaticResource PanelBackground}"
                CornerRadius="8" Margin="5,0,0,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Total Portfolio Summary -->
                    <TextBlock Text="Total Portfolio (All Accounts)" FontSize="16" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Total Value:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock x:Name="TotalPortfolioValue" Text="-" Foreground="{StaticResource TextPrimary}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Day P&amp;L:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock x:Name="TotalDayPnL" Text="-" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Total P&amp;L:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock x:Name="TotalPnL" Text="-" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Active Accts:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock x:Name="ActiveAccounts" Text="-" Foreground="{StaticResource AccentBlue}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Live Positions:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock x:Name="LivePositionsCount" Text="-" Foreground="{StaticResource AccentBlue}" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Performance Metrics -->
                    <Separator Background="#404040" Margin="0,10,0,20"/>
                    <TextBlock Text="Performance (Today)" FontSize="16" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Win Rate:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock Text="73%" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Avg Win:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock Text="$487" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Avg Loss:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock Text="-$156" Foreground="{StaticResource AccentRed}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Profit Factor:" Foreground="{StaticResource TextSecondary}" Width="90"/>
                            <TextBlock Text="3.12" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Quick Actions -->
                    <Separator Background="#404040" Margin="0,10,0,20"/>
                    <TextBlock Text="Quick Actions" FontSize="16" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                    <Button Content="📊 View Full Reports" Style="{StaticResource ModernButton}"
                           Margin="0,0,0,10" Click="ViewReports_Click"/>
                    <Button Content="⚙️ Risk Settings" Style="{StaticResource ModernButton}"
                           Margin="0,0,0,10" Click="RiskSettings_Click"/>
                    <Button Content="🔔 Notifications" Style="{StaticResource ModernButton}"
                           Margin="0,0,0,10" Click="Notifications_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
