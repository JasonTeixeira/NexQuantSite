<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="brainGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ec4899;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0.8" />
    </linearGradient>
    <linearGradient id="chipGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:0.8" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="#0f172a"/>
  
  <!-- Brain (left side) -->
  <g transform="translate(80, 150)">
    <path d="M0 0 C-20 -40, 20 -60, 40 -30 C60 -50, 80 -20, 60 10 C80 30, 60 50, 40 40 C20 60, -20 40, 0 0 Z" 
          fill="url(#brainGrad)" opacity="0.8"/>
    <!-- Brain details -->
    <path d="M10 -20 Q30 -15, 25 5 Q35 15, 15 20" stroke="#ec4899" stroke-width="2" fill="none" opacity="0.6"/>
    <path d="M-5 -10 Q15 -5, 10 15" stroke="#8b5cf6" stroke-width="1.5" fill="none" opacity="0.6"/>
    <circle cx="20" cy="-10" r="3" fill="#fbbf24" opacity="0.7"/>
    <circle cx="35" cy="5" r="2" fill="#10b981" opacity="0.7"/>
  </g>
  
  <!-- VS Text -->
  <text x="200" y="155" text-anchor="middle" fill="#e5e7eb" font-family="Arial" font-size="24" font-weight="bold">VS</text>
  
  <!-- Computer Chip (right side) -->
  <g transform="translate(280, 120)">
    <!-- Main chip body -->
    <rect x="0" y="0" width="60" height="60" fill="url(#chipGrad)" rx="4"/>
    
    <!-- Circuit lines -->
    <line x1="10" y1="15" x2="50" y2="15" stroke="#06b6d4" stroke-width="1.5"/>
    <line x1="10" y1="30" x2="50" y2="30" stroke="#3b82f6" stroke-width="1.5"/>
    <line x1="10" y1="45" x2="50" y2="45" stroke="#06b6d4" stroke-width="1.5"/>
    <line x1="15" y1="10" x2="15" y2="50" stroke="#3b82f6" stroke-width="1.5"/>
    <line x1="30" y1="10" x2="30" y2="50" stroke="#06b6d4" stroke-width="1.5"/>
    <line x1="45" y1="10" x2="45" y2="50" stroke="#3b82f6" stroke-width="1.5"/>
    
    <!-- Pins -->
    <rect x="-5" y="12" width="5" height="6" fill="#374151"/>
    <rect x="-5" y="27" width="5" height="6" fill="#374151"/>
    <rect x="-5" y="42" width="5" height="6" fill="#374151"/>
    <rect x="60" y="12" width="5" height="6" fill="#374151"/>
    <rect x="60" y="27" width="5" height="6" fill="#374151"/>
    <rect x="60" y="42" width="5" height="6" fill="#374151"/>
    
    <!-- Central processing core -->
    <rect x="20" y="20" width="20" height="20" fill="#1e40af" opacity="0.8" rx="2"/>
    <circle cx="30" cy="30" r="6" fill="#06b6d4" opacity="0.6"/>
  </g>
  
  <!-- Title -->
  <text x="200" y="40" text-anchor="middle" fill="#e5e7eb" font-family="Arial" font-size="18" font-weight="bold">Human Intelligence vs AI</text>
  <text x="200" y="270" text-anchor="middle" fill="#9ca3af" font-family="Arial" font-size="12">The Future of Trading Technology</text>
</svg>
