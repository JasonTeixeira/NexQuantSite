<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="screenGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.6" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="#0c0d0f"/>
  
  <!-- Desk/workspace -->
  <rect x="0" y="200" width="400" height="100" fill="#1f2937"/>
  
  <!-- Monitor screens -->
  <rect x="50" y="80" width="120" height="80" fill="#000000" rx="4"/>
  <rect x="52" y="82" width="116" height="76" fill="url(#screenGlow)" opacity="0.8" rx="2"/>
  
  <rect x="200" y="90" width="100" height="70" fill="#000000" rx="4"/>
  <rect x="202" y="92" width="96" height="66" fill="#1e40af" opacity="0.6" rx="2"/>
  
  <!-- Code on screens -->
  <g transform="translate(55, 90)">
    <line x1="5" y1="10" x2="40" y2="10" stroke="#10b981" stroke-width="1.5"/>
    <line x1="5" y1="20" x2="60" y2="20" stroke="#06b6d4" stroke-width="1"/>
    <line x1="15" y1="30" x2="50" y2="30" stroke="#3b82f6" stroke-width="1"/>
    <line x1="5" y1="40" x2="35" y2="40" stroke="#10b981" stroke-width="1"/>
    <line x1="15" y1="50" x2="70" y2="50" stroke="#06b6d4" stroke-width="1"/>
    <line x1="5" y1="60" x2="45" y2="60" stroke="#fbbf24" stroke-width="1"/>
  </g>
  
  <!-- Developer figure -->
  <g transform="translate(280, 140)">
    <!-- Body/Shirt -->
    <rect x="-15" y="20" width="30" height="40" fill="#374151" rx="4"/>
    
    <!-- Head -->
    <circle cx="0" cy="0" r="12" fill="#fbbf24" opacity="0.9"/>
    
    <!-- Hair -->
    <path d="M-10 -8 Q0 -15, 10 -8 Q8 -12, 0 -12 Q-8 -12, -10 -8" fill="#7c2d12" opacity="0.8"/>
    
    <!-- Arms typing -->
    <rect x="-20" y="25" width="8" height="20" fill="#374151" rx="3"/>
    <rect x="12" y="25" width="8" height="20" fill="#374151" rx="3"/>
    
    <!-- Hands on keyboard -->
    <ellipse cx="-16" cy="50" rx="3" ry="2" fill="#fbbf24" opacity="0.8"/>
    <ellipse cx="16" cy="50" rx="3" ry="2" fill="#fbbf24" opacity="0.8"/>
    
    <!-- Keyboard -->
    <rect x="-25" y="48" width="50" height="8" fill="#1f2937" rx="2"/>
    <rect x="-23" y="50" width="6" height="4" fill="#374151" rx="1"/>
    <rect x="-15" y="50" width="6" height="4" fill="#374151" rx="1"/>
    <rect x="-7" y="50" width="6" height="4" fill="#374151" rx="1"/>
    <rect x="1" y="50" width="6" height="4" fill="#374151" rx="1"/>
    <rect x="9" y="50" width="6" height="4" fill="#374151" rx="1"/>
    <rect x="17" y="50" width="6" height="4" fill="#374151" rx="1"/>
  </g>
  
  <!-- Coffee cup -->
  <g transform="translate(320, 180)">
    <ellipse cx="0" cy="8" rx="6" ry="3" fill="#7c2d12"/>
    <rect x="-6" y="0" width="12" height="8" fill="#7c2d12"/>
    <path d="M6 2 Q12 2, 12 8 Q12 12, 6 12" fill="none" stroke="#7c2d12" stroke-width="1.5"/>
    <!-- Steam -->
    <path d="M-2 -2 Q-1 -8, 0 -2 Q1 -8, 2 -2" stroke="#9ca3af" stroke-width="1" fill="none" opacity="0.6"/>
  </g>
  
  <!-- Floating code elements -->
  <text x="350" y="60" fill="#10b981" font-family="monospace" font-size="12" opacity="0.7">{ }</text>
  <text x="30" y="50" fill="#06b6d4" font-family="monospace" font-size="10" opacity="0.6">function()</text>
  <text x="320" y="40" fill="#3b82f6" font-family="monospace" font-size="8" opacity="0.6">const API</text>
  
  <!-- Title -->
  <text x="200" y="30" text-anchor="middle" fill="#e5e7eb" font-family="Arial" font-size="18" font-weight="bold">Senior Developer</text>
  <text x="200" y="280" text-anchor="middle" fill="#9ca3af" font-family="Arial" font-size="12">Trading Platform Architecture</text>
</svg>
