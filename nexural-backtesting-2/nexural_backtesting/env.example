# Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# AI API Keys (Ensemble Configuration)
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Data Provider API Keys
DATABENTO_API_KEY=your_databento_key_here
QUANTCONNECT_USER_ID=your_qc_user_id_here
QUANTCONNECT_TOKEN=your_qc_token_here

# Database (for enterprise features)
DATABASE_URL=postgresql://user:pass@localhost:5432/backtesting
REDIS_URL=redis://localhost:6379/0

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Security
SECRET_KEY=your_secret_key_for_encryption
JWT_SECRET=your_jwt_secret_for_auth

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# NinjaTrader Path
NINJATRADER_EXPORT_PATH=C:/Users/YourUser/Documents/NinjaTrader 8/trace/