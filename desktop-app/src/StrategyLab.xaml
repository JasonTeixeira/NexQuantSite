            <Border Grid.Column="2" Background="{StaticResource PanelBackground}">
                <ScrollViewer>
                    <StackPanel Margin="20">
                                                        <TextBlock Text="📊 BACKTESTING &amp; ANALYTICS" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,0,0,25"/>

                        <!-- Backtest Settings -->
                        <TextBlock Text="📅 BACKTEST PERIOD" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Start Date" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBox x:Name="StartDateInput" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                         BorderBrush="#404040" Padding="10,8" Text="2024-01-01"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="End Date" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBox x:Name="EndDateInput" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                         BorderBrush="#404040" Padding="10,8" Text="2024-12-31"/>
                            </StackPanel>
                        </Grid>

                        <!-- Initial Capital -->
                        <TextBlock Text="💰 INITIAL CAPITAL" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>
                        <TextBox x:Name="InitialCapitalInput" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="#404040" Padding="10,8" Margin="0,0,0,25" Text="$100,000"/>

                        <!-- Performance Metrics -->
                        <TextBlock Text="📈 PERFORMANCE METRICS" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <Border Background="#2A2A2A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
                                    <TextBlock Text="Total Return" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="TotalReturnValue" Text="+45.2%" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="0">
                                    <TextBlock Text="Sharpe Ratio" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="SharpeRatioValue" Text="2.47" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,15,10,0">
                                    <TextBlock Text="Max Drawdown" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="MaxDrawdownValue" Text="-8.3%" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentRed}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,15,0,0">
                                    <TextBlock Text="Win Rate" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="WinRateValue" Text="73.5%" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,15,10,0">
                                    <TextBlock Text="Profit Factor" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="ProfitFactorValue" Text="1.85" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="2" Margin="0,15,0,0">
                                    <TextBlock Text="Total Trades" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="TotalTradesValue" Text="1,247" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,15,10,0">
                                    <TextBlock Text="Avg Trade" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="AvgTradeValue" Text="+$362" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="3" Margin="0,15,0,0">
                                    <TextBlock Text="Calmar Ratio" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="CalmarRatioValue" Text="5.45" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- AI Optimization -->
                        <TextBlock Text="🤖 AI OPTIMIZATION" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <Border Background="#2A2A2A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🎯 AI Suggestions:" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10"/>
                                <TextBlock Text="• Increase RSI period to 21 for better signals"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Add volume confirmation filter"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Optimize stop loss to 1.8% for better R:R"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Consider adding volatility filter"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Use ensemble model for higher accuracy"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Border>

                        <!-- Risk Analysis -->
                        <TextBlock Text="🛡️ RISK ANALYSIS" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                        <Border Background="#2A2A2A" CornerRadius="8" Padding="20" Margin="0,0,0,25">
                            <StackPanel>
                                <TextBlock Text="📊 Risk Metrics:" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10"/>
                                <TextBlock Text="• VaR (95%): -$2,450"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Expected Shortfall: -$3,120"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Beta: 0.85"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Correlation: 0.72"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Sortino Ratio: 3.12"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <Button Content="🚀 RUN BACKTEST" Background="{StaticResource AccentBlue}"
                                Foreground="Black" FontWeight="Bold" Padding="15,12" Margin="0,0,0,12" FontSize="14"/>
                        <Button Content="🤖 AI OPTIMIZE" Background="{StaticResource AccentOrange}"
                                Foreground="Black" FontWeight="Bold" Padding="15,10" Margin="0,0,0,12" FontSize="14"/>
                        <Button Content="📊 GENERATE REPORT" Background="{StaticResource AccentGreen}"
                                Foreground="Black" FontWeight="Bold" Padding="15,10" Margin="0,0,0,12" FontSize="14"/>
                        <Button Content="🎯 DEPLOY STRATEGY" Background="{StaticResource AccentRed}"
                                Foreground="White" FontWeight="Bold" Padding="15,10" FontSize="14"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
