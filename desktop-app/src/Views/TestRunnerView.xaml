<UserControl x:Class="QuantumTrader.Views.TestRunnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource NexusAIBackgroundPrimary}"
            BorderBrush="{StaticResource NexusAIBorderPrimary}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Testing Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource NexusAIAccentPrimary}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🧪" FontSize="24" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="COMPREHENSIVE TESTING SUITE"
                                     FontWeight="Bold"
                                     FontSize="16"
                                     Foreground="{StaticResource NexusAITextPrimary}"/>
                            <TextBlock Text="Test every button, function, and component"
                                     FontSize="12"
                                     Foreground="{StaticResource NexusAITextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border x:Name="TestStatusIndicator" Background="#FFA500" CornerRadius="12" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock x:Name="TestStatusText" Text="READY" FontWeight="Bold" FontSize="12" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Test Control Buttons -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="RunAllTestsButton"
                        Content="🧪 RUN ALL TESTS"
                        Style="{StaticResource NexusButtonPrimary}"
                        Click="RunAllTestsButton_Click"
                        Margin="0,0,4,0"/>

                <Button Grid.Column="1"
                        x:Name="QuickTestButton"
                        Content="⚡ QUICK TEST"
                        Style="{StaticResource NexusButtonSuccess}"
                        Click="QuickTestButton_Click"
                        Margin="2,0,2,0"/>

                <Button Grid.Column="2"
                        x:Name="StressTestButton"
                        Content="💪 STRESS TEST"
                        Style="{StaticResource NexusButtonSecondary}"
                        Click="StressTestButton_Click"
                        Margin="2,0,2,0"/>

                <Button Grid.Column="3"
                        x:Name="ViewReportsButton"
                        Content="📊 VIEW REPORTS"
                        Style="{StaticResource NexusButtonSecondary}"
                        Click="ViewReportsButton_Click"
                        Margin="4,0,0,0"/>
            </Grid>

            <!-- Progress Display -->
            <Border Grid.Row="2"
                    Background="{StaticResource NexusAIBackgroundSecondary}"
                    BorderBrush="{StaticResource NexusAIBorderSecondary}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                 x:Name="ProgressText"
                                 Text="Ready to run tests"
                                 FontSize="14"
                                 Foreground="{StaticResource NexusAITextPrimary}"/>

                        <TextBlock Grid.Column="1"
                                 x:Name="ProgressPercentage"
                                 Text="0%"
                                 FontSize="14"
                                 FontWeight="Bold"
                                 Foreground="{StaticResource NexusAIAccentPrimary}"/>
                    </Grid>

                    <ProgressBar Grid.Row="1"
                               x:Name="TestProgressBar"
                               Height="8"
                               Margin="0,8,0,0"
                               Background="{StaticResource NexusAIBackgroundTertiary}"
                               Foreground="{StaticResource NexusAIAccentPrimary}"
                               Minimum="0"
                               Maximum="100"
                               Value="0"/>
                </Grid>
            </Border>

            <!-- Test Results Display -->
            <Border Grid.Row="3"
                    Background="{StaticResource NexusAIBackgroundSecondary}"
                    BorderBrush="{StaticResource NexusAIBorderSecondary}"
                    BorderThickness="1"
                    CornerRadius="6">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource NexusAIAccentSecondary}"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                     Text="🧪 TEST RESULTS"
                                     FontWeight="Bold"
                                     FontSize="14"
                                     Foreground="{StaticResource NexusAITextPrimary}"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="TestResultsSummary"
                                         Text="No tests run"
                                         FontSize="12"
                                         Foreground="{StaticResource NexusAITextSecondary}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="12">
                        <ItemsControl x:Name="TestResultsDisplay">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource NexusAIBackgroundTertiary}"
                                            BorderBrush="{StaticResource NexusAIBorderTertiary}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                     Text="{Binding Icon}"
                                                     FontSize="16"
                                                     Margin="0,0,8,0"
                                                     VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                     Text="{Binding TestName}"
                                                     FontSize="12"
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource NexusAITextPrimary}"
                                                     VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                     Text="{Binding Message}"
                                                     FontSize="10"
                                                     Foreground="{StaticResource NexusAITextTertiary}"
                                                     Margin="8,0"
                                                     VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3"
                                                     Text="{Binding ExecutionTime}"
                                                     FontSize="10"
                                                     Foreground="{StaticResource NexusAITextTertiary}"
                                                     VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>









