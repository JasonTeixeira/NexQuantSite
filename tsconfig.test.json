{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    // Allow more flexible typing for tests
    "noImplicitAny": false,
    "strict": false
  },
  "include": [
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    "**/__mocks__/**/*.ts",
    "**/__mocks__/**/*.tsx",
    "jest.setup.js",
    "jest.config.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
