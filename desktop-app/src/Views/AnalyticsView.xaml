<UserControl x:Class="QuantumTrader.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Professional Analytics Header -->
        <Border Grid.Row="0"
                Background="#1A1A25"
                BorderBrush="#2A2A3E"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📈 ADVANCED ANALYTICS &amp; REPORTING"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Institutional-grade portfolio analytics, performance attribution, and risk analysis"
                               Foreground="#A0A0B8"
                               FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📊 Generate Report"
                            Style="{StaticResource NexusButton}"
                            Background="#228B22"
                            Margin="0,0,12,0"/>
                    <Button Content="📥 Export Data"
                            Style="{StaticResource NexusButton}"
                            Background="#00BBFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Analytics Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Key Performance Indicators -->
                <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🎯 KEY PERFORMANCE INDICATORS"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <!-- KPI Grid -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Portfolio Value -->
                            <Border Grid.Row="0" Grid.Column="0"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="💰 PORTFOLIO VALUE" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="$485,670" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="+$10,440 (+2.2%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Daily P&L -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="📈 DAILY P&amp;L" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="+$2,341" Foreground="Green" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="+$450 (+23.8%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Sharpe Ratio -->
                            <Border Grid.Row="0" Grid.Column="2"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="📊 SHARPE RATIO" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="2.34" Foreground="#00BBFF" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="+0.06 (+2.6%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Win Rate -->
                            <Border Grid.Row="0" Grid.Column="3"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="🎯 WIN RATE" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="68.5%" Foreground="Orange" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="+1.7% (+2.5%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Max Drawdown -->
                            <Border Grid.Row="1" Grid.Column="0"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="📉 MAX DRAWDOWN" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="8.7%" Foreground="Orange" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="-0.5% (-5.4%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Risk Score -->
                            <Border Grid.Row="1" Grid.Column="1"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="⚖️ RISK SCORE" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="34/100" Foreground="Orange" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="-4 (-10.5%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Active Strategies -->
                            <Border Grid.Row="1" Grid.Column="2"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="🤖 ACTIVE STRATEGIES" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="4" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="+1 (+33.3%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Monthly Return -->
                            <Border Grid.Row="1" Grid.Column="3"
                                    Background="#1A1A25"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="📅 MONTHLY RETURN" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="6.7%" Foreground="Green" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="+0.8% (+13.6%)" Foreground="Green" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Performance Attribution Analysis -->
                <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🎭 PERFORMANCE ATTRIBUTION ANALYSIS"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <!-- Attribution Table -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Strategy / Account" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Contribution" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="%" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Alpha" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Risk" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="Trades" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Grade" FontWeight="Bold" Foreground="#A0A0B8" Padding="8"/>

                            <!-- Row 1: Momentum Scalper -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Momentum Scalper / Live Acc 1" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="+$8,750" Foreground="Green" Padding="8" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="42.3%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="$3,451" Foreground="#00BBFF" Padding="8"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="23.4%" Foreground="Orange" Padding="8"/>
                            <TextBlock Grid.Row="1" Grid.Column="5" Text="247" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="1" Grid.Column="6" Text="A+" Foreground="Green" Padding="8" FontWeight="Bold"/>

                            <!-- Row 2: Mean Reversion Pro -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Mean Reversion Pro / Live Acc 2" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="+$6,235" Foreground="Green" Padding="8" FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="30.1%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="$2,890" Foreground="#00BBFF" Padding="8"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="18.7%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="2" Grid.Column="5" Text="189" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="2" Grid.Column="6" Text="A" Foreground="Green" Padding="8" FontWeight="Bold"/>

                            <!-- Row 3: Breakout Hunter -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Breakout Hunter / Live Acc 3" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="+$4,567" Foreground="Green" Padding="8" FontWeight="Bold"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="22.0%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="$1,890" Foreground="#00BBFF" Padding="8"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="15.2%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="3" Grid.Column="5" Text="134" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="3" Grid.Column="6" Text="B+" Foreground="Orange" Padding="8" FontWeight="Bold"/>

                            <!-- Row 4: Smart Grid Pro -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Smart Grid Pro / Sim Acc 1" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="+$1,157" Foreground="Green" Padding="8" FontWeight="Bold"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="5.6%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="$679" Foreground="#00BBFF" Padding="8"/>
                            <TextBlock Grid.Row="4" Grid.Column="4" Text="8.1%" Foreground="Green" Padding="8"/>
                            <TextBlock Grid.Row="4" Grid.Column="5" Text="67" Foreground="White" Padding="8"/>
                            <TextBlock Grid.Row="4" Grid.Column="6" Text="B" Foreground="Orange" Padding="8" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Risk Scenario Analysis -->
                <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="⚠️ RISK SCENARIO ANALYSIS"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <!-- Market Crash Scenario -->
                        <Border Background="#1A1A25" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Market Crash (-20%)" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Simulated 20% market decline" FontSize="10" Foreground="#A0A0B8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Impact" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-$97,340" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Impact %" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-20.0%" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Worst Case" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-$145,600" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Loss Prob." Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="95.0%" Foreground="White" FontWeight="Bold"/>
                                </StackPanel>
                                <Border Grid.Column="5" Background="Red" CornerRadius="8" Padding="8,4">
                                    <TextBlock Text="HIGH" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Volatility Spike Scenario -->
                        <Border Background="#1A1A25" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Volatility Spike (+50%)" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="50% increase in market volatility" FontSize="10" Foreground="#A0A0B8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Impact" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-$23,450" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Impact %" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-4.8%" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Worst Case" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-$56,780" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Loss Prob." Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="72.0%" Foreground="White" FontWeight="Bold"/>
                                </StackPanel>
                                <Border Grid.Column="5" Background="Orange" CornerRadius="8" Padding="8,4">
                                    <TextBlock Text="MED" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Black Swan Event -->
                        <Border Background="#1A1A25" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Black Swan Event" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Extreme market event (5σ deviation)" FontSize="10" Foreground="#A0A0B8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Impact" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-$243,560" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Impact %" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-50.1%" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Worst Case" Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="-$389,450" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Loss Prob." Style="{StaticResource NexusTextCaption}"/>
                                    <TextBlock Text="99.8%" Foreground="White" FontWeight="Bold"/>
                                </StackPanel>
                                <Border Grid.Column="5" Background="Purple" CornerRadius="8" Padding="8,4">
                                    <TextBlock Text="EXTR" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Advanced Charts -->
                <Border Style="{StaticResource NexusCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📊 ADVANCED PORTFOLIO CHARTS"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Equity Curve Chart -->
                            <Border Grid.Column="0"
                                    Background="#0F0F1A"
                                    CornerRadius="8"
                                    Margin="0,0,8,0"
                                    Height="250">
                                <StackPanel Margin="16">
                                    <TextBlock Text="📈 PORTFOLIO EQUITY CURVE"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <Canvas Height="180" Background="#050508">
                                        <!-- Equity curve line -->
                                        <Polyline Points="20,150 60,140 100,120 140,110 180,90 220,75 260,65 300,55 340,45 380,35"
                                                  Stroke="Green"
                                                  StrokeThickness="3"/>

                                        <!-- Chart labels -->
                                        <TextBlock Canvas.Left="20" Canvas.Top="160" Text="Jan" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="180" Canvas.Top="160" Text="May" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="340" Canvas.Top="160" Text="Sep" Foreground="#888" FontSize="10"/>

                                        <TextBlock Canvas.Left="5" Canvas.Top="140" Text="$450K" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="5" Canvas.Top="90" Text="$475K" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="5" Canvas.Top="40" Text="$500K" Foreground="#888" FontSize="10"/>
                                    </Canvas>
                                </StackPanel>
                            </Border>

                            <!-- Strategy Performance -->
                            <Border Grid.Column="1"
                                    Background="#0F0F1A"
                                    CornerRadius="8"
                                    Margin="8,0,0,0"
                                    Height="250">
                                <StackPanel Margin="16">
                                    <TextBlock Text="🏆 STRATEGY PERFORMANCE RANKING"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <Canvas Height="180" Background="#050508">
                                        <!-- Performance bars -->
                                        <Rectangle Canvas.Left="50" Canvas.Top="30" Width="40" Height="120" Fill="Green"/>
                                        <Rectangle Canvas.Left="110" Canvas.Top="60" Width="40" Height="90" Fill="#00BBFF"/>
                                        <Rectangle Canvas.Left="170" Canvas.Top="90" Width="40" Height="60" Fill="Orange"/>
                                        <Rectangle Canvas.Left="230" Canvas.Top="120" Width="40" Height="30" Fill="Yellow"/>

                                        <!-- Labels -->
                                        <TextBlock Canvas.Left="45" Canvas.Top="160" Text="Mom" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="105" Canvas.Top="160" Text="MR" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="165" Canvas.Top="160" Text="BO" Foreground="#888" FontSize="10"/>
                                        <TextBlock Canvas.Left="225" Canvas.Top="160" Text="Grid" Foreground="#888" FontSize="10"/>

                                        <!-- Performance values -->
                                        <TextBlock Canvas.Left="45" Canvas.Top="10" Text="42.3%" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Canvas.Left="105" Canvas.Top="40" Text="30.1%" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Canvas.Left="165" Canvas.Top="70" Text="22.0%" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Canvas.Left="225" Canvas.Top="100" Text="5.6%" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Canvas>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Alert Rules Management -->
                <Border Style="{StaticResource NexusCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="🚨 ALERT RULES &amp; NOTIFICATIONS"
                                       Style="{StaticResource NexusHeaderMedium}"/>

                            <Button Grid.Column="1"
                                    Content="➕ Add Alert"
                                    Style="{StaticResource NexusButton}"
                                    Background="#FF6B35"/>
                        </Grid>

                        <!-- Alert Rules List -->
                        <StackPanel>
                            <!-- Daily Loss Limit Alert -->
                            <Border Background="#1A1A25" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Daily Loss Limit" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Alert when daily loss exceeds threshold" FontSize="10" Foreground="#A0A0B8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Daily P&amp;L" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Less than" Foreground="#00BBFF"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="-$5,000" Foreground="White" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Border Grid.Column="4" Background="Red" CornerRadius="8" Padding="6,2">
                                        <TextBlock Text="HIGH" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <CheckBox Grid.Column="5" IsChecked="True" Content="Enabled" Foreground="White" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Drawdown Warning Alert -->
                            <Border Background="#1A1A25" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Drawdown Warning" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Alert when drawdown exceeds 10%" FontSize="10" Foreground="#A0A0B8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Max Drawdown" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Greater than" Foreground="#00BBFF"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="10%" Foreground="White" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Border Grid.Column="4" Background="Purple" CornerRadius="8" Padding="6,2">
                                        <TextBlock Text="CRIT" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <CheckBox Grid.Column="5" IsChecked="True" Content="Enabled" Foreground="White" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Performance Alert -->
                            <Border Background="#1A1A25" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
