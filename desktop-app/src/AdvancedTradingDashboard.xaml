                                    <TextBlock Text="• Backtest results available" Foreground="#8B949E"/>
                                    <TextBlock Text="• Optimization suggestions" Foreground="#8B949E"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
