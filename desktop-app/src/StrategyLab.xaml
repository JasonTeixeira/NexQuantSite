                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,0">
                                    <TextBlock Text="Temperature" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                    <Slider x:Name="TemperatureSlider" Minimum="0" Maximum="2" Value="0.7"
                                            Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                    <TextBlock x:Name="TemperatureValue" Text="0.7" FontSize="10"
