<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="placeholderGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#374151;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4b5563;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="url(#placeholderGrad)"/>
  
  <!-- Grid pattern -->
  <defs>
    <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
      <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#6b7280" stroke-width="0.5" opacity="0.3"/>
    </pattern>
  </defs>
  <rect width="400" height="300" fill="url(#grid)"/>
  
  <!-- Placeholder icon -->
  <g transform="translate(200, 150)">
    <!-- Image frame -->
    <rect x="-60" y="-40" width="120" height="80" fill="none" stroke="#9ca3af" stroke-width="2" rx="4"/>
    
    <!-- Mountain/landscape icon -->
    <path d="M-50 10 L-30 -10 L-10 10 L10 -20 L30 10 L50 10" 
          fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    
    <!-- Sun -->
    <circle cx="25" cy="-15" r="8" fill="none" stroke="#9ca3af" stroke-width="2"/>
    <path d="M25 -30 v-5 M40 -15 h5 M35 -30 l3 -3 M35 0 l3 3 M25 0 v5 M10 -15 h-5 M15 -30 l-3 -3 M15 0 l-3 3" 
          stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
  </g>
  
  <!-- Placeholder text -->
  <text x="200" y="220" text-anchor="middle" fill="#9ca3af" font-family="Arial" font-size="16" font-weight="bold">Image Placeholder</text>
  <text x="200" y="240" text-anchor="middle" fill="#6b7280" font-family="Arial" font-size="12">400 × 300</text>
  
  <!-- Corner dots -->
  <circle cx="30" cy="30" r="2" fill="#9ca3af" opacity="0.5"/>
  <circle cx="370" cy="30" r="2" fill="#9ca3af" opacity="0.5"/>
  <circle cx="30" cy="270" r="2" fill="#9ca3af" opacity="0.5"/>
  <circle cx="370" cy="270" r="2" fill="#9ca3af" opacity="0.5"/>
</svg>
