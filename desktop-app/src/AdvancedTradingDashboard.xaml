<Window x:Class="QuantumTrader.AdvancedTradingDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚡ Elite Trading ML - Advanced Trading Dashboard"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0F1419">

    <Window.Resources>
        <SolidColorBrush x:Key="DarkBackground">#0F1419</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBackground">#1A2332</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBlue">#00D4FF</SolidColorBrush>
        <SolidColorBrush x:Key="AccentGreen">#00FF88</SolidColorBrush>
        <SolidColorBrush x:Key="AccentRed">#FF4757</SolidColorBrush>
        <SolidColorBrush x:Key="AccentOrange">#FFA500</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimary">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#8B949E</SolidColorBrush>

        <!-- Tab Style -->
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="#404040" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="⚡" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="ELITE TRADING ML" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                    <TextBlock Text="Advanced Trading Dashboard" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Status Indicators -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentGreen}" Margin="5,0"/>
                    <TextBlock Text="ML Server" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>

                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentGreen}" Margin="15,0,5,0"/>
                    <TextBlock Text="Backend" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>

                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentRed}" Margin="15,0,5,0"/>
                    <TextBlock Text="NinjaTrader" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>

                <!-- Time -->
                <TextBlock Grid.Column="2" x:Name="TimeDisplay" Text="14:30:25"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="14" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl Grid.Row="1" Background="{StaticResource DarkBackground}" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <StaticResource ResourceKey="TabStyle"/>
            </TabControl.ItemContainerStyle>

            <!-- TAB 1: Control Center -->
            <TabItem Header="📊 Control Center">
                <ScrollViewer>
                    <StackPanel x:Name="ControlCenterContent" Margin="20">
                        <!-- Multi-Account Overview -->
                        <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🏦 MULTI-ACCOUNT OVERVIEW" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>

                                <!-- Account Grid -->
                                <Grid x:Name="AccountGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Account Cards will be added here dynamically -->
                                </Grid>

                                <!-- Collective P&amp;L -->
                                <Border Background="#2A2A2A" CornerRadius="6" Padding="15" Margin="0,15,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Total P&amp;L" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="TotalPnL" Text="+$45,230.50" FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentGreen}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Active Accounts" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="ActiveAccounts" Text="7/10" FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBlue}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Total Volume" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="TotalVolume" Text="1,247" FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="Win Rate" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="WinRate" Text="78.5%" FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentGreen}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Strategy Performance -->
                        <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🤖 STRATEGY PERFORMANCE" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>

                                <!-- Strategy Grid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Strategy Cards will be added here dynamically -->
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Risk Engine Controls -->
                        <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🛡️ RISK ENGINE CONTROLS" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Global Risk Settings -->
                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock Text="Global Risk Settings" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Max Daily Loss (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <Slider x:Name="MaxDailyLossSlider" Minimum="1" Maximum="10" Value="5"
                                                    Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                            <TextBlock x:Name="MaxDailyLossValue" Text="5%" FontSize="12"
                                                       Foreground="{StaticResource AccentBlue}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Max Position Size (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <Slider x:Name="MaxPositionSizeSlider" Minimum="1" Maximum="20" Value="10"
                                                    Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                            <TextBlock x:Name="MaxPositionSizeValue" Text="10%" FontSize="12"
                                                       Foreground="{StaticResource AccentBlue}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Stop Loss (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <Slider x:Name="StopLossSlider" Minimum="0.5" Maximum="5" Value="2"
                                                    Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                            <TextBlock x:Name="StopLossValue" Text="2%" FontSize="12"
                                                       Foreground="{StaticResource AccentBlue}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Account-Specific Controls -->
                                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                                        <TextBlock Text="Account Controls" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                        <ComboBox x:Name="AccountSelector" Margin="0,0,0,10"
                                                  Background="{StaticResource PanelBackground}"
                                                  Foreground="{StaticResource TextPrimary}">
                                            <ComboBoxItem Content="Account 1 - Live"/>
                                            <ComboBoxItem Content="Account 2 - Sim"/>
                                            <ComboBoxItem Content="Account 3 - Live"/>
                                        </ComboBox>

                                        <CheckBox x:Name="EnableTrading" Content="Enable Trading"
                                                  Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="EnableRiskManagement" Content="Enable Risk Management"
                                                  Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="EnableAutoScaling" Content="Enable Auto Scaling"
                                                  Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>

                                        <Button Content="Apply Settings" Background="{StaticResource AccentBlue}"
                                                Foreground="Black" FontWeight="Bold" Padding="15,8" Margin="0,10,0,0"/>
                                    </StackPanel>

                                    <!-- Emergency Controls -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Emergency Controls" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentRed}" Margin="0,0,0,10"/>

                                        <Button Content="🛑 EMERGENCY STOP ALL" Background="{StaticResource AccentRed}"
                                                Foreground="White" FontWeight="Bold" Padding="15,10" Margin="0,0,0,10"/>

                                        <Button Content="📊 FLATTEN POSITIONS" Background="{StaticResource AccentOrange}"
                                                Foreground="White" FontWeight="Bold" Padding="15,8" Margin="0,0,0,10"/>

                                        <Button Content="🔄 RESET RISK LIMITS" Background="{StaticResource AccentBlue}"
                                                Foreground="White" FontWeight="Bold" Padding="15,8" Margin="0,0,0,10"/>

                                        <TextBlock Text="⚠️ Use emergency controls carefully!" FontSize="10"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Strategy Lab -->
            <TabItem Header="🧠 Strategy Lab">
                <ScrollViewer>
                    <Grid x:Name="StrategyLabContent" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🧠 STRATEGY LAB - AI-POWERED QUANT DEVELOPMENT"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,5"/>
                                    <TextBlock Text="World-Class Strategy Development Platform with Advanced AI Integration"
                                               FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="🚀 NEW STRATEGY" Background="{StaticResource AccentGreen}"
                                            Foreground="Black" FontWeight="Bold" Padding="15,8" Margin="0,0,10,0"/>
                                    <Button Content="📊 BACKTEST" Background="{StaticResource AccentBlue}"
                                            Foreground="Black" FontWeight="Bold" Padding="15,8" Margin="0,0,10,0"/>
                                    <Button Content="🤖 AI ASSIST" Background="{StaticResource AccentOrange}"
                                            Foreground="Black" FontWeight="Bold" Padding="15,8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Main Content -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="350"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Panel: Strategy Builder -->
                            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="🔧 STRATEGY BUILDER" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,20"/>

                                    <!-- Strategy Name -->
                                    <TextBlock Text="Strategy Name" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                    <TextBox x:Name="StrategyNameInput" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                             BorderBrush="#404040" Padding="10,8" Margin="0,0,0,15"
                                             Text="My AI Strategy"/>

                                    <!-- AI Model Selection -->
                                    <TextBlock Text="🤖 AI MODEL SELECTION" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                    <RadioButton x:Name="AutoModeRadio" Content="🎯 AUTO MODE (AI Optimizes)"
                                                 Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5" IsChecked="True"/>
                                    <RadioButton x:Name="ManualModeRadio" Content="⚙️ MANUAL SELECTION"
                                                 Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

                                    <!-- Pay-as-you-go Credits System -->
                                    <Border Background="#2A2A2A" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="💳 PAY-AS-YOU-GO CREDITS" FontSize="14" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentGreen}" Margin="0,0,0,10"/>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Available Credits" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock x:Name="AvailableCredits" Text="$1,245.00" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentGreen}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <Button Content="💳 ADD CREDITS" Background="{StaticResource AccentGreen}"
                                                            Foreground="Black" FontWeight="Bold" Padding="10,5" FontSize="11"
                                                            Click="AddCredits_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="AI Generation Cost" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="$5.00 per strategy" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBlue}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                                    <TextBlock Text="Backtest Cost" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="$2.50 per test" FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBlue}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="0,10,0,0">
                                                <TextBlock Text="💡 Credits are deducted automatically when using AI features. Add more anytime!"
                                                           FontSize="10" Foreground="{StaticResource TextSecondary}" TextWrapping="NoWrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Model Selection (Manual Mode) -->
                                    <StackPanel x:Name="ManualModelPanel" Visibility="Collapsed">
                                        <ComboBox x:Name="ModelSelector" Margin="0,0,0,10"
                                                  Background="#2A2A2A" Foreground="{StaticResource TextPrimary}">
                                            <ComboBoxItem Content="🧠 GPT-4 Turbo (Advanced Reasoning)"/>
                                            <ComboBoxItem Content="🤖 Claude 3.5 Sonnet (Quantitative Analysis)"/>
                                            <ComboBoxItem Content="⚡ Claude 3.5 Haiku (Fast Execution)"/>
                                            <ComboBoxItem Content="🎯 Custom Fine-tuned Model"/>
                                            <ComboBoxItem Content="🔬 Ensemble (Multi-Model)"/>
                                        </ComboBox>

                                        <TextBlock Text="Model Parameters" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,5,0">
                                                <TextBlock Text="Temperature" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                                <Slider x:Name="TemperatureSlider" Minimum="0" Maximum="2" Value="0.7"
                                                        Foreground="{StaticResource AccentBlue}" Margin="0,2"/>
                                                <TextBlock x:Name="TemperatureValue" Text="0.7" FontSize="10"
                                                           Foreground="{StaticResource AccentBlue}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="5,0,0,0">
                                                <TextBlock Text="Creativity" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                                <Slider x:Name="CreativitySlider" Minimum="0" Maximum="1" Value="0.5"
                                                        Foreground="{StaticResource AccentBlue}" Margin="0,2"/>
                                                <TextBlock x:Name="CreativityValue" Text="0.5" FontSize="10"
                                                           Foreground="{StaticResource AccentBlue}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Strategy Type -->
                                    <TextBlock Text="📈 STRATEGY TYPE" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                    <ComboBox x:Name="StrategyTypeSelector" Margin="0,0,0,15"
                                              Background="#2A2A2A" Foreground="{StaticResource TextPrimary}">
                                        <ComboBoxItem Content="🎯 Mean Reversion"/>
                                        <ComboBoxItem Content="📈 Momentum"/>
                                        <ComboBoxItem Content="⚡ Scalping"/>
                                        <ComboBoxItem Content="🛡️ Arbitrage"/>
                                        <ComboBoxItem Content="🧠 ML-Based"/>
                                        <ComboBoxItem Content="🔮 Sentiment"/>
                                        <ComboBoxItem Content="📊 Statistical Arbitrage"/>
                                        <ComboBoxItem Content="🎲 Custom"/>
                                    </ComboBox>

                                    <!-- Instruments -->
                                    <TextBlock Text="💰 TRADING INSTRUMENTS" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                    <ListBox x:Name="InstrumentSelector" Height="100" Background="#2A2A2A"
                                             Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15">
                                        <ListBoxItem Content="ES - E-mini S&amp;P 500" IsSelected="True"/>
                                        <ListBoxItem Content="NQ - E-mini NASDAQ-100"/>
                                        <ListBoxItem Content="YM - E-mini Dow"/>
                                        <ListBoxItem Content="RTY - E-mini Russell 2000"/>
                                        <ListBoxItem Content="CL - Crude Oil"/>
                                        <ListBoxItem Content="GC - Gold"/>
                                        <ListBoxItem Content="ZB - 30-Year Treasury"/>
                                        <ListBoxItem Content="6E - Euro FX"/>
                                    </ListBox>

                                    <!-- Timeframe -->
                                    <TextBlock Text="⏰ TIMEFRAME" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                    <ComboBox x:Name="TimeframeSelector" Margin="0,0,0,15"
                                              Background="#2A2A2A" Foreground="{StaticResource TextPrimary}">
                                        <ComboBoxItem Content="1 minute"/>
                                        <ComboBoxItem Content="5 minutes"/>
                                        <ComboBoxItem Content="15 minutes"/>
                                        <ComboBoxItem Content="1 hour"/>
                                        <ComboBoxItem Content="4 hours"/>
                                        <ComboBoxItem Content="1 day"/>
                                    </ComboBox>

                                    <!-- Risk Settings -->
                                    <TextBlock Text="🛡️ RISK SETTINGS" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Max Position Size (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <Slider x:Name="MaxPositionSlider" Minimum="1" Maximum="20" Value="5"
                                                Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                        <TextBlock x:Name="MaxPositionValue" Text="5%" FontSize="12"
                                                   Foreground="{StaticResource AccentBlue}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Stop Loss (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <Slider x:Name="StopLossSlider_StrategyLab" Minimum="0.5" Maximum="5" Value="2"
                                                Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                        <TextBlock x:Name="StopLossValue_StrategyLab" Text="2%" FontSize="12"
                                                   Foreground="{StaticResource AccentBlue}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="Take Profit (%)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <Slider x:Name="TakeProfitSlider" Minimum="1" Maximum="10" Value="4"
                                                Foreground="{StaticResource AccentBlue}" Margin="0,5"/>
                                        <TextBlock x:Name="TakeProfitValue" Text="4%" FontSize="12"
                                                   Foreground="{StaticResource AccentBlue}"/>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <Button Content="🧠 GENERATE WITH AI" Background="{StaticResource AccentBlue}"
                                            Foreground="Black" FontWeight="Bold" Padding="15,10" Margin="0,0,0,10"
                                            Click="GenerateStrategyWithAI_Click"/>
                                    <Button Content="💾 SAVE STRATEGY" Background="{StaticResource AccentGreen}"
                                            Foreground="Black" FontWeight="Bold" Padding="15,8" Margin="0,0,0,10"/>
                                    <Button Content="📊 QUICK BACKTEST" Background="{StaticResource AccentOrange}"
                                            Foreground="Black" FontWeight="Bold" Padding="15,8"
                                            Click="BacktestStrategy_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Center Panel: AI Code Editor -->
                            <Border Grid.Column="1" Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="🤖 AI-POWERED CODE EDITOR" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlue}"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="🔍 ANALYZE" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                                    Padding="10,5" Margin="0,0,5,0"/>
                                            <Button Content="⚡ OPTIMIZE" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                                    Padding="10,5" Margin="0,0,5,0" Click="OptimizeStrategy_Click"/>
                                            <Button Content="🧪 TEST" Background="#2A2A2A" Foreground="{StaticResource TextPrimary}"
                                                    Padding="10,5"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Code Editor -->
                                    <Border Background="#1A1A1A" CornerRadius="6" Padding="15" Height="400">
                                        <ScrollViewer>
