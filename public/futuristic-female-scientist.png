<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="labGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#334155;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glowGrad" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.1" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="url(#labGrad)"/>
  
  <!-- Lab background elements -->
  <rect x="50" y="80" width="120" height="80" fill="#374151" opacity="0.6" rx="8"/>
  <rect x="230" y="100" width="100" height="60" fill="#374151" opacity="0.6" rx="8"/>
  
  <!-- Holographic displays -->
  <circle cx="110" cy="120" r="25" fill="none" stroke="#06b6d4" stroke-width="2" opacity="0.8"/>
  <path d="M95 120 L125 120 M110 105 L110 135" stroke="#06b6d4" stroke-width="1.5" opacity="0.6"/>
  
  <rect x="240" y="110" width="80" height="40" fill="none" stroke="#3b82f6" stroke-width="1.5" opacity="0.8"/>
  <line x1="250" y1="120" x2="310" y2="120" stroke="#3b82f6" stroke-width="1" opacity="0.6"/>
  <line x1="250" y1="130" x2="310" y2="130" stroke="#3b82f6" stroke-width="1" opacity="0.6"/>
  <line x1="250" y1="140" x2="310" y2="140" stroke="#3b82f6" stroke-width="1" opacity="0.6"/>
  
  <!-- Female scientist figure (simplified) -->
  <g transform="translate(180, 140)">
    <!-- Lab coat -->
    <path d="M-20 40 Q-15 20, 0 15 Q15 20, 20 40 L25 80 L-25 80 Z" fill="#f8fafc" opacity="0.9"/>
    
    <!-- Head/Hair -->
    <circle cx="0" cy="0" r="15" fill="#fbbf24" opacity="0.8"/>
    <path d="M-12 -8 Q0 -20, 12 -8 Q8 -15, 0 -15 Q-8 -15, -12 -8" fill="#7c2d12" opacity="0.8"/>
    
    <!-- Arms -->
    <rect x="-25" y="30" width="8" height="25" fill="#f8fafc" opacity="0.9" rx="4"/>
    <rect x="17" y="30" width="8" height="25" fill="#f8fafc" opacity="0.9" rx="4"/>
    
    <!-- Hands holding device -->
    <circle cx="30" cy="40" r="4" fill="#fbbf24" opacity="0.8"/>
    <rect x="26" y="35" width="8" height="12" fill="#1e40af" opacity="0.8" rx="2"/>
    <circle cx="30" cy="41" r="2" fill="#06b6d4" opacity="1"/>
  </g>
  
  <!-- Data streams/particles -->
  <circle cx="300" cy="60" r="2" fill="#06b6d4" opacity="0.8">
    <animate attributeName="opacity" values="0.3;1;0.3" dur="2s" repeatCount="indefinite"/>
  </circle>
  <circle cx="320" cy="80" r="1.5" fill="#3b82f6" opacity="0.8">
    <animate attributeName="opacity" values="0.5;1;0.5" dur="1.5s" repeatCount="indefinite"/>
  </circle>
  <circle cx="290" cy="90" r="1" fill="#10b981" opacity="0.8">
    <animate attributeName="opacity" values="0.4;1;0.4" dur="1.8s" repeatCount="indefinite"/>
  </circle>
  
  <!-- Floating data points -->
  <rect x="100" y="50" width="3" height="3" fill="#06b6d4" opacity="0.7" rx="1">
    <animateTransform attributeName="transform" type="translate" values="0,0; 10,-5; 0,0" dur="3s" repeatCount="indefinite"/>
  </rect>
  
  <!-- Title and subtitle -->
  <text x="200" y="35" text-anchor="middle" fill="#e5e7eb" font-family="Arial" font-size="18" font-weight="bold">Research Scientist</text>
  <text x="200" y="280" text-anchor="middle" fill="#9ca3af" font-family="Arial" font-size="12">Advanced Financial Modeling</text>
  
  <!-- Glow effect -->
  <ellipse cx="200" cy="200" rx="150" ry="100" fill="url(#glowGrad)" opacity="0.3"/>
</svg>
