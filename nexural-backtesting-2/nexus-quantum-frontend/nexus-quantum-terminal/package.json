{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "debug:server": "NODE_OPTIONS='--inspect-brk' next dev",
    "debug:build": "NODE_OPTIONS='--inspect' next build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true npm run build",
    "profile": "node --cpu-prof --cpu-prof-dir=./profiles node_modules/.bin/next build",
    "trace": "node --trace-warnings npm run dev",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "jest --testPathPattern=performance",
    "test:integration": "jest --testPathPattern=integration",
    "test:components": "jest --testPathPattern=components",
    "test:all": "npm run test:ci && npm run test:e2e",
    "playwright:install": "playwright install",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "logs:audit": "tail -f logs/audit.log",
    "logs:clear": "rm -rf logs/*",
    "sentry:upload": "npx @sentry/wizard -i nextjs",
    "bundle:analyze": "npm run analyze && open bundle-analysis.html"
  },
