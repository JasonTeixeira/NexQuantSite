<Window x:Class="QuantumTrader.SimpleDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧠 Quantum Trader Professional - ML-Powered Trading Platform"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F1419">

    <Window.Resources>
        <SolidColorBrush x:Key="DarkBackground">#0F1419</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBackground">#1A2332</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBlue">#00D4FF</SolidColorBrush>
        <SolidColorBrush x:Key="AccentGreen">#00FF88</SolidColorBrush>
        <SolidColorBrush x:Key="AccentRed">#FF4757</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimary">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#8B949E</SolidColorBrush>

        <!-- Navigation Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#404040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="#404040" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                        <Grid>
                            <Grid>
                                <Ellipse Width="26" Height="26">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                            <GradientStop Color="#8000FF41" Offset="0"/>
                                            <GradientStop Color="#3300FF41" Offset="0.4"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="24" Height="24" Stroke="#00FF41" StrokeThickness="1" Opacity="0.5" Fill="Transparent"/>
                                <Ellipse Width="20" Height="20" Stroke="#00FF41" StrokeThickness="0.5" Opacity="0.3" Fill="Transparent"/>
                                <Ellipse Width="16" Height="16" Stroke="#00FF41" StrokeThickness="0.5" Opacity="0.2" Fill="Transparent"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="2" Height="6" Fill="#00FF41">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00FF41" ShadowDepth="0" Opacity="0.6"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="9" Fill="#00FF41" Margin="2,0,0,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00FF41" ShadowDepth="0" Opacity="0.6"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="12" Fill="#00FF41" Margin="2,0,0,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00FF41" ShadowDepth="0" Opacity="0.6"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="14" Fill="#00FF41" Margin="2,0,0,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00FF41" ShadowDepth="0" Opacity="0.6"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="10" Fill="#00FF41" Margin="2,0,0,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00FF41" ShadowDepth="0" Opacity="0.6"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="7" Fill="#00FF41" Margin="2,0,0,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00FF41" ShadowDepth="0" Opacity="0.6"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                            </StackPanel>
                        </Grid>
                    </Viewbox>
                    <TextBlock Text="QUANTUM TRADER" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                    <TextBlock Text="Professional ML-Powered Trading Platform" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Status Indicators -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentGreen}" Margin="5,0"/>
                    <TextBlock Text="ML Server" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>

                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentGreen}" Margin="15,0,5,0"/>
                    <TextBlock Text="Backend" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>

                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentRed}" Margin="15,0,5,0"/>
                    <TextBlock Text="NinjaTrader" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>

                <!-- Time -->
                <TextBlock Grid.Column="2" x:Name="TimeDisplay" Text="14:30:25"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="14" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="#404040" BorderThickness="0,0,1,0">
                <StackPanel Margin="20">
                    <TextBlock Text="🎯 TRADING DASHBOARD" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,20"/>

                    <!-- Navigation Buttons -->
                    <Button Content="📊 Control Center" Style="{StaticResource NavButtonStyle}"
                            Click="ControlCenter_Click" Margin="0,5"/>
                    <Button Content="🧠 Strategy Lab" Style="{StaticResource NavButtonStyle}"
                            Click="StrategyLab_Click" Margin="0,5"/>
                    <Button Content="🛒 Strategy Store" Style="{StaticResource NavButtonStyle}"
                            Click="Store_Click" Margin="0,5"/>
                    <Button Content="👤 Account Manager" Style="{StaticResource NavButtonStyle}"
                            Click="AccountManager_Click" Margin="0,5"/>
                    <Button Content="📈 Analytics" Style="{StaticResource NavButtonStyle}"
                            Click="Analytics_Click" Margin="0,5"/>

                    <Separator Margin="0,20" Background="#404040"/>

                    <!-- Accounts Management (Phase 1) -->
                    <TextBlock Text="👤 ACCOUNTS" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>

                    <!-- Account Limit Status -->
                    <Border Background="#2A2A2A" Padding="8" Margin="0,0,0,8">
                        <TextBlock Text="{Binding AccountLimitMessage}"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" FontSize="12"/>
                    </Border>

                    <!-- Account Switcher -->
                    <TextBlock Text="📋 Account Switcher" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,8,0,4"/>
                    <ComboBox ItemsSource="{Binding AccountSwitcher}"
                              SelectedItem="{Binding SelectedAccount}"
                              DisplayMemberPath="Name"
                              Width="220" Margin="0,0,0,8"/>

                    <!-- Account Controls -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="＋ Add" Style="{StaticResource NavButtonStyle}" Width="70"
                                Command="{Binding AddAccountCommand}"
                                IsEnabled="{Binding CanAddAccount}"/>
                        <Button Content="💾 Save" Style="{StaticResource NavButtonStyle}" Width="70"
                                Command="{Binding SaveAccountCommand}"/>
                        <Button Content="🗑 Delete" Style="{StaticResource NavButtonStyle}" Width="70"
                                Command="{Binding DeleteAccountCommand}"/>
                    </StackPanel>

                    <!-- Account List -->
                    <Border Background="#2A2A2A" Padding="10" Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding Accounts}"
                                 SelectedItem="{Binding SelectedAccount}"
                                 DisplayMemberPath="Name"
                                 Height="80"/>
                    </Border>

                    <!-- Account Editor -->
                    <TextBlock Text="✏️ ACCOUNT DETAILS" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,10,0,6"/>
                    <Border Background="#2A2A2A" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Name:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                <TextBox Text="{Binding EditingAccount.Name}" Width="140"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Type:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                <ComboBox SelectedItem="{Binding EditingAccount.Type}" Width="140">
                                    <ComboBoxItem Content="Sim"/>
                                    <ComboBoxItem Content="Live"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Broker:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                <TextBox Text="{Binding EditingAccount.Broker}" Width="140"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Balance:" Foreground="{StaticResource TextSecondary}" Width="80"/>
                                <TextBox Text="{Binding EditingAccount.Balance}" Width="140"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource AccentRed}"
                                       FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Strategy Assignment (Phase 1) -->
                    <TextBlock Text="🧩 STRATEGY ASSIGNMENT" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,10,0,6"/>
                    <Border Background="#2A2A2A" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Available Strategies" Foreground="{StaticResource TextSecondary}"/>
                            <ComboBox ItemsSource="{Binding Strategies}" DisplayMemberPath="Name" Width="220"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="➕ Assign" Style="{StaticResource NavButtonStyle}" Width="100"
                                        Command="{Binding AssignCommand}"/>
                                <Button Content="💾 Save" Style="{StaticResource NavButtonStyle}" Width="100"
                                        Command="{Binding SaveAssignmentsCommand}"/>
                            </StackPanel>

                            <!-- Defaults Button -->
                            <Button Content="⚙️ Apply Defaults" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding ApplyDefaultsCommand}"
                                    Margin="0,6,0,0" Width="220"/>

                            <TextBlock Text="Assigned to Account" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Assignments}" Height="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding Enabled}"
                                                      Command="{Binding DataContext.ToggleStrategyCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding StrategyName}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Assignment Details -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Min" Foreground="{StaticResource TextSecondary}" Width="40"/>
                                <TextBox Text="{Binding SelectedAssignment.MinContracts}" Width="60"/>
                                <TextBlock Text="Max" Foreground="{StaticResource TextSecondary}" Width="40" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding SelectedAssignment.MaxContracts}" Width="60"/>
                                <TextBlock Text="Alloc %" Foreground="{StaticResource TextSecondary}" Width="60" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding SelectedAssignment.AllocationPct}" Width="60"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,20" Background="#404040"/>

                    <!-- Active Strategies -->
                    <TextBlock Text="🤖 ACTIVE STRATEGIES" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                    <Border Background="#2A2A2A" Padding="15" Margin="0,10">
                        <StackPanel>
                            <TextBlock Text="🎯 Mean Reversion Pro" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                            <TextBlock Text="Performance: +15.2%" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/>

                            <TextBlock Text="📈 Momentum Scalper" Foreground="{StaticResource AccentGreen}" FontWeight="Bold" Margin="0,10,0,0"/>
                            <TextBlock Text="Performance: +8.7%" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/>

                            <TextBlock Text="🧠 Neural Ensemble" Foreground="{StaticResource AccentGreen}" FontWeight="Bold" Margin="0,10,0,0"/>
                            <TextBlock Text="Performance: +22.3%" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Border Grid.Column="1" Background="{StaticResource DarkBackground}">
                <ScrollViewer>
                    <StackPanel x:Name="MainContent" Margin="30">
                        <!-- Welcome Content -->
                        <TextBlock Text="🚀 Welcome to Quantum Trader Professional"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock Text="Professional ML-Powered Trading Platform"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,40"/>

                        <!-- Feature Grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Feature Cards -->
                            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource PanelBackground}"
                                    CornerRadius="8" Margin="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🎯 Real-Time Trading" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Professional trading interface with real-time market data, order management, and execution capabilities."
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource PanelBackground}"
                                    CornerRadius="8" Margin="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🧠 AI-Powered Strategies" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Advanced machine learning models including CatBoost, LightGBM, XGBoost, and neural networks for predictive trading."
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource PanelBackground}"
                                    CornerRadius="8" Margin="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="📊 Performance Analytics" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Comprehensive performance tracking, risk metrics, and detailed analytics with professional reporting."
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource PanelBackground}"
                                    CornerRadius="8" Margin="10" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🛡️ Enterprise Security" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Bank-grade security with 2FA, encryption, audit logging, and compliance features for institutional use."
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Risk Panel (Phase 3) on the right side of content -->
                        <Grid Margin="0,30,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: existing demo status -->
                            <Border Grid.Column="0" Background="#1A4B3A" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="🔧 Demo Mode Active" FontSize="16" FontWeight="Bold"
                                               Foreground="White" Margin="0,0,0,10"/>
                                    <TextBlock Text="This is a demonstration of the Quantum Trader Professional interface. All features shown are fully functional in the production version."
                                               Foreground="LightGray" TextWrapping="Wrap"/>
                                    <TextBlock Text="Click the navigation buttons on the left to explore different sections of the application."
                                               Foreground="LightGray" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Right: Risk editor (Phase 3) -->
                            <Border Grid.Column="1" Background="#2A2A2A" CornerRadius="8" Padding="16" Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="🛡️ RISK ENGINE (Phase 3)" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>

                                    <!-- Risk Badge (Phase 3) -->
                                    <Border Background="#1A4B3A" CornerRadius="4" Padding="8" Margin="0,8,0,8">
                                        <StackPanel>
                                            <TextBlock Text="🎯 RISK BADGE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                                            <TextBlock Text="{Binding Risk.RiskProfile.MinContracts, StringFormat='Min: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="10"/>
                                            <TextBlock Text="{Binding Risk.RiskProfile.MaxContracts, StringFormat='Max: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="10"/>
                                            <TextBlock Text="{Binding Risk.RiskProfile.ConfidenceGamma, StringFormat='Gamma: {0:F2}'}" Foreground="{StaticResource TextSecondary}" FontSize="10"/>
                                            <TextBlock Text="🔒 Daily Lockout: Active" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Min C:" Foreground="{StaticResource TextSecondary}" Width="60"/>
                                        <TextBox Text="{Binding Risk.RiskProfile.MinContracts}" Width="60"/>
                                        <TextBlock Text="Max C:" Foreground="{StaticResource TextSecondary}" Width="60" Margin="10,0,0,0"/>
                                        <TextBox Text="{Binding Risk.RiskProfile.MaxContracts}" Width="60"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Max Daily Loss %:" Foreground="{StaticResource TextSecondary}" Width="140"/>
                                        <TextBox Text="{Binding Risk.RiskProfile.MaxDailyLossPct}" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Max Position %:" Foreground="{StaticResource TextSecondary}" Width="140"/>
                                        <TextBox Text="{Binding Risk.RiskProfile.MaxPositionRiskPct}" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                        <TextBlock Text="Gamma:" Foreground="{StaticResource TextSecondary}" Width="140"/>
                                        <TextBox Text="{Binding Risk.RiskProfile.ConfidenceGamma}" Width="80"/>
                                    </StackPanel>
                                    <Button Content="💾 Save Profile" Background="{StaticResource AccentGreen}" Foreground="Black" Command="{Binding Risk.SaveProfileCommand}"/>

                                    <Separator Margin="0,10,0,10"/>

                                    <!-- Daily Lockout Status (Phase 3) -->
                                    <Border Background="#4B1A1A" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="🔒 DAILY LOCKOUT STATUS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentRed}"/>
                                            <TextBlock Text="Daily Loss: -2.5% / -5.0%" Foreground="{StaticResource TextSecondary}" FontSize="10"/>
                                            <TextBlock Text="Status: Active (Auto-flatten enabled)" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Max-DD Auto-Close (Phase 3) -->
                                    <Border Background="#1A1A4B" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="📉 MAX-DD AUTO-CLOSE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                                            <TextBlock Text="Current DD: -1.2%" Foreground="{StaticResource TextSecondary}" FontSize="10"/>
                                            <TextBlock Text="Threshold: -3.0% (Auto-close enabled)" Foreground="{StaticResource AccentBlue}" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="🎯 Test Sizing" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Confidence:" Foreground="{StaticResource TextSecondary}" Width="140"/>
                                        <TextBox Text="{Binding Risk.InputConfidence}" Width="80"/>
                                        <TextBlock Text="→ Recommended:" Foreground="{StaticResource TextSecondary}" Margin="10,0,0,0"/>
                                        <TextBlock Text="{Binding Risk.RecommendedContracts}" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                                    </StackPanel>

                                    <TextBlock Text="🧪 Simulate Order" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,10,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Proposed Risk %:" Foreground="{StaticResource TextSecondary}" Width="140"/>
                                        <TextBox Text="{Binding Risk.InputProposedRiskPct}" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                        <TextBlock Text="Session PnL %:" Foreground="{StaticResource TextSecondary}" Width="140"/>
                                        <TextBox Text="{Binding Risk.InputSessionPnLPct}" Width="80"/>
                                    </StackPanel>
                                    <Button Content="▶ Simulate" Background="{StaticResource AccentBlue}" Command="{Binding Risk.SimulateOrderCommand}"/>
                                    <TextBlock Text="{Binding Risk.LastDecision.Reason}" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Risk.LastDecision.Contracts}" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource PanelBackground}" BorderBrush="#404040" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="© 2024 Nexural Technologies. All rights reserved."
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0"/>
                <TextBlock Text="Demo Version - Professional Features Available"
                           Foreground="{StaticResource AccentBlue}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>
    </Grid>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>
</Window>
