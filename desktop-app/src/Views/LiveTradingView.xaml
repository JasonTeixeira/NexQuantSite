<UserControl x:Class="QuantumTrader.Views.LiveTradingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Global Portfolio Health -->
            <Border Style="{StaticResource NexusCard}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Total P&amp;L" Style="{StaticResource NexusTextCaption}"/>
                        <TextBlock Text="{Binding TotalPnLFormatted}"
                                   Style="{StaticResource NexusTextSuccess}"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Daily P&amp;L" Style="{StaticResource NexusTextCaption}"/>
                        <TextBlock Text="{Binding DailyPnLFormatted}"
                                   Style="{StaticResource NexusTextSuccess}"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="Unrealized P&amp;L" Style="{StaticResource NexusTextCaption}"/>
                        <TextBlock Text="{Binding UnrealizedPnLFormatted}"
                                   Style="{StaticResource NexusTextSuccess}"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Portfolio Risk" Style="{StaticResource NexusTextCaption}"/>
                        <TextBlock Text="{Binding PortfolioRiskScoreFormatted}"
                                   Foreground="{StaticResource NexusAccentPrimary}"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Global Operations Panel -->
            <Border Style="{StaticResource NexusCard}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bulk Actions -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🌐 BULK ACTIONS:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   Style="{StaticResource NexusHeaderSmall}"/>
                        <Button Content="🛑 STOP ALL"
                                Style="{StaticResource NexusButtonError}"
                                Command="{Binding StopAllAccountsCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="⏸️ PAUSE ALL"
                                Style="{StaticResource NexusButtonSecondary}"
                                Command="{Binding PauseAllAccountsCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="▶️ START ALL"
                                Style="{StaticResource NexusButtonSuccess}"
                                Command="{Binding StartAllAccountsCommand}"
                                Margin="0,0,8,0"/>
                    </StackPanel>

                    <!-- Portfolio Metrics -->
                    <StackPanel Grid.Column="1" Margin="16,0">
                        <TextBlock Text="Total Exposure" Style="{StaticResource NexusTextCaption}"/>
                        <TextBlock Text="{Binding TotalExposureFormatted}"
                                   Style="{StaticResource NexusTextMono}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Broker Status -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Broker Status" Style="{StaticResource NexusTextCaption}"/>
                        <TextBlock Text="{Binding BrokerStatusFormatted}"
                                   Foreground="{StaticResource NexusSuccess}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Individual Account Controls -->
            <Border Style="{StaticResource NexusCard}">
                <StackPanel>
                    <TextBlock Text="📊 INDIVIDUAL ACCOUNT CONTROLS"
                               Style="{StaticResource NexusHeaderMedium}"
                               Margin="0,0,0,16"/>

                    <!-- Account Grid -->
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource NexusCard}"
                                        Margin="4"
                                        Background="{StaticResource NexusBackgroundTertiary}">
                                    <StackPanel>

                                        <!-- Account Header -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding AccountTypeIcon}"
                                                           FontSize="16"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding AccountDisplayName}"
                                                           Style="{StaticResource NexusHeaderSmall}"
                                                           FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding DailyPnLFormatted}"
                                                           Style="{StaticResource NexusTextSuccess}"
                                                           FontWeight="Bold"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Account Details Grid -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Strategy Selection -->
                                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                                                <TextBlock Text="🤖 STRATEGY" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding CurrentStrategy}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Content="🔄 CHANGE"
                                                        Style="{StaticResource NexusButtonSecondary}"
                                                        FontSize="10"
                                                        Padding="8,4"
                                                        Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- Risk Parameters -->
                                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,8,8">
                                                <TextBlock Text="⚖️ RISK" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding RiskPerTrade, StringFormat={}{0:F1}%}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding DailyLossLimit, StringFormat={}${0:F0} limit}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource NexusTextTertiary}"/>
                                            </StackPanel>

                                            <!-- Performance -->
                                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,8">
                                                <TextBlock Text="📊 PERFORMANCE" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding WinRateFormatted}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SharpeRatioFormatted, StringFormat={}Sharpe {0}}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource NexusTextTertiary}"/>
                                            </StackPanel>

                                            <!-- Positions -->
                                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,8">
                                                <TextBlock Text="⚡ POSITIONS" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding Positions}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Status -->
                                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,8,8">
                                                <TextBlock Text="🔔 STATUS" Style="{StaticResource NexusTextCaption}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="12"/>
                                                    <TextBlock Text="Active"
                                                               FontWeight="SemiBold"
                                                               Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- P&L Details -->
                                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,8">
                                                <TextBlock Text="💰 UNREALIZED" Style="{StaticResource NexusTextCaption}"/>
                                                <TextBlock Text="{Binding UnrealizedPnL, StringFormat={}+${0:F2}}"
                                                           Style="{StaticResource NexusTextSuccess}"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- Account Controls -->
                                            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        Margin="0,8,0,0">
                                                <Button Content="▶️"
                                                        Style="{StaticResource NexusButtonSuccess}"
                                                        Command="{Binding StartAccountCommand}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Margin="0,0,4,0"
                                                        ToolTip="Start Account"/>
                                                <Button Content="⏸️"
                                                        Style="{StaticResource NexusButtonSecondary}"
                                                        Command="{Binding PauseAccountCommand}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Margin="0,0,4,0"
                                                        ToolTip="Pause Account"/>
                                                <Button Content="⏹️"
                                                        Style="{StaticResource NexusButtonSecondary}"
                                                        Command="{Binding StopAccountCommand}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Margin="0,0,4,0"
                                                        ToolTip="Stop Account"/>
                                                <Button Content="🚨"
                                                        Style="{StaticResource NexusButtonError}"
                                                        Command="{Binding EmergencyStopCommand}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Margin="0,0,4,0"
                                                        ToolTip="Emergency Stop"/>
                                                <Button Content="⚙️"
                                                        Style="{StaticResource NexusButtonSecondary}"
                                                        Command="{Binding ConfigureAccountCommand}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Margin="0,0,4,0"
                                                        ToolTip="Configure Account"/>
                                                <Button Content="📊"
                                                        Style="{StaticResource NexusButtonSecondary}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        ToolTip="Account Details"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add Account Section -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource NexusCard}"
                                Background="{StaticResource NexusBackgroundTertiary}"
                                Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                <TextBlock Text="➕ ADD LIVE ACCOUNT"
                                           Style="{StaticResource NexusHeaderSmall}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Connect to NinjaTrader"
                                           Style="{StaticResource NexusTextCaption}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,8"/>
                                <Button Content="🏦 ADD LIVE"
                                        Style="{StaticResource NexusButtonPrimary}"
                                        Command="{Binding AddLiveAccountCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource NexusCard}"
                                Background="{StaticResource NexusBackgroundTertiary}"
                                Margin="4,0,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                <TextBlock Text="➕ ADD SIM ACCOUNT"
                                           Style="{StaticResource NexusHeaderSmall}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Paper Trading Mode"
                                           Style="{StaticResource NexusTextCaption}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,8"/>
                                <Button Content="🎯 ADD SIM"
                                        Style="{StaticResource NexusButtonSecondary}"
                                        Command="{Binding AddSimAccountCommand}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Emergency Controls -->
            <Border Style="{StaticResource NexusCard}"
                    BorderBrush="{StaticResource NexusError}"
                    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🚨 EMERGENCY CONTROLS"
                                   Style="{StaticResource NexusHeaderMedium}"
                                   Foreground="{StaticResource NexusError}"/>
                        <TextBlock Text="Global kill switch and emergency controls for all accounts"
                                   Style="{StaticResource NexusTextCaption}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🛑 GLOBAL KILL SWITCH"
                                Style="{StaticResource NexusButtonError}"
                                Command="{Binding EmergencyStopCommand}"
                                FontWeight="Bold"
                                Padding="16,8"/>
                        <TextBlock Text="📞 Emergency: +1-555-NEXUS (24/7)"
                                   Style="{StaticResource NexusTextCaption}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
